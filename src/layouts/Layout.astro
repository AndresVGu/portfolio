---
import '@fontsource-variable/onest';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { ViewTransitions } from "astro:transitions"

interface Props {
	title: string; 
	description: string;
}

const { description,title } = Astro.props;
const { currentLocale } = Astro
---

<!doctype html>
<html lang={currentLocale}> 
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <ViewTransitions />

    <!-- Auto-detect language on first visit and redirect -->
    <script is:inline>
      (function () {
        // Only redirect if the user hasn't manually chosen a language yet
        if (typeof localStorage === 'undefined') return;
        if (localStorage.getItem('lang-redirected')) return;

        const path = window.location.pathname;
        // Already on a localised route — don't redirect
        if (path.startsWith('/es') || path.startsWith('/fr')) return;

        const lang = (navigator.language || navigator.userLanguage || 'en')
          .toLowerCase()
          .slice(0, 2);

        localStorage.setItem('lang-redirected', '1');

        if (lang === 'es') {
          window.location.replace('/es/');
        } else if (lang === 'fr') {
          window.location.replace('/fr/');
        }
        // Default: stay on English
      })();
    </script>

    <!-- Apply dark/light theme before paint to avoid flash -->
    <script is:inline>
      (function applyStoredTheme() {
        const stored = typeof localStorage !== 'undefined'
          ? localStorage.getItem('theme')
          : null;
        const preference = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = preference === 'dark' || (preference === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      })();

      // Re-apply after every ViewTransitions navigation so the class is never lost
      document.addEventListener('astro:after-swap', function () {
        const stored = typeof localStorage !== 'undefined'
          ? localStorage.getItem('theme')
          : null;
        const preference = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = preference === 'dark' || (preference === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      });
    </script>
	</head>
	<body class="relative text-black dark:text-white ">
		<div
		class="absolute top-0 bottom-0 z-[-2] min-h-screen w-full bg-gray-50 dark:bg-gray-950
		bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(217,216,255,0.5),rgba(255,255,255,0.9))]
		dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"
	  >
	  </div>
		<Header currentLocale={currentLocale} />
		<slot />
		<Footer currentLocale={currentLocale} />
  <style is:global>
    :root {
      
      color-scheme: light dark;
    }
    html {
      font-family:"Onest Variable", system-ui, sans-serif;
      scroll-behavior: smooth;
      
    }
    body{
     color: rgba(17, 17, 17, 0.9);
          display:flex;
          flex-direction: column;
          min-height: 100vh;
          overscroll-behavior: none;
  
    }
  
    @media (prefers-reduced-motion: reduce) {
          html {
            scroll-behavior: auto;
          }
        }
  
        /* Use .dark class (controlled by ThemeToggle) instead of media query */
        .dark body {
          color: rgba(255, 255, 255, 0.9);
        }
  
        #header-menu{
          border-radius: 25px;
        }
        #header-nav {
          animation: blur linear both 0.5s;
          animation-timeline: scroll();
          border: none;
          
        }
  
        @keyframes blur {
          to {
            backdrop-filter: blur(20px);
            border-width: 1px;
            border-color: rgba(0, 0, 0);
            padding: 0.25rem 0.75rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            background-color: rgb(229, 229, 229);
            border-radius: 9999px;
          }
        }
  
        /* Dark mode nav blur — driven by .dark class, not media query */
        html.dark #header-nav {
          animation: blur-dark linear both 0.5s;
          animation-timeline: scroll();
        }

        @keyframes blur-dark {
            from {
              border: 0px;
            }
            to {
              box-shadow:
                0px 5px 50px -5px rgba(0, 0, 0, 0.1),
                0px 0px 0 1px rgba(0, 0, 0, 0.3);
              background: rgba(0, 0, 0, 0.3);
              backdrop-filter: blur(20px);
              border-width: 1px;
              border-color: rgba(0, 0, 0);
              padding-left: 0.75rem;
              padding-right: 0.75rem;
              padding-top: 0.25rem;
              padding-bottom: 0.25rem;
              display: flex;
              flex-direction: row;
              align-items: center;
              background-color: rgba(0, 0, 0, 0.3);
              border-radius: 9999px;
            }
        }
    
  </style>

<script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
	</body>
  
</html>

