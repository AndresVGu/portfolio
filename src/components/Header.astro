---
import ThemeToggle from '../components/ThemeToggle.astro';
import Close from './Icons/Close.astro';
import Menu from './Icons/Menu.astro';
import { getI18N, getLocalePath } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const base = getLocalePath(currentLocale);

const navItems = [
  { title: i18n.NAV.home,       label: 'home',       url: `${base}/#home` },
  { title: i18n.NAV.experience, label: 'experience', url: `${base}/#experience` },
  { title: i18n.NAV.projects,   label: 'projects',   url: `${base}/#projects` },
  { title: i18n.NAV.education,  label: 'education',  url: `${base}/#education` },
  { title: i18n.NAV.about,      label: 'about',      url: `${base}/#about` },
  { title: i18n.NAV.contact,    label: 'contact',    url: `${base}/#contact` },
];

const languages = [
  { label: 'EN', locale: 'en', href: '/' },
  { label: 'ES', locale: 'es', href: '/es/' },
  { label: 'FR', locale: 'fr', href: '/fr/' },
];
---

<!-- ═══════════════════════════════════════════════════════════════════════
     HEADER
     Desktop (lg+): pill nav centered at top
     Tablet (md–lg): same pill but smaller text
     Mobile (<md):  hamburger button + full-screen overlay drawer
     ═══════════════════════════════════════════════════════════════════════ -->
<header id="site-header"
        class="fixed top-0 left-0 right-0 z-40 flex items-center justify-between
               px-4 sm:px-6 h-14 sm:h-16
               transition-all duration-300">

  <!-- ── Logo / brand (mobile only) ──────────────────────────────────── -->
  <a href={`${base}/#home`}
     class="md:hidden font-bold text-sm text-gray-800 dark:text-gray-100 tracking-wide select-none">
    AV<span class="text-yellow-500">.</span>
  </a>

  <!-- ── Desktop pill nav ─────────────────────────────────────────────── -->
  <nav id="desktop-nav"
       class="hidden md:flex items-center gap-1 lg:gap-2
              mx-auto
              px-3 py-1.5 rounded-full
              text-sm lg:text-base">

    {navItems.map((link) => (
      <a
        class="nav-link px-3 py-1.5 rounded-full font-medium transition-colors duration-200
               text-gray-600 dark:text-gray-300
               hover:text-gray-900 dark:hover:text-white
               hover:bg-gray-100 dark:hover:bg-gray-800"
        aria-label={link.label}
        href={link.url}
      >
        {link.title}
      </a>
    ))}

    <!-- Divider -->
    <span class="w-px h-5 bg-gray-200 dark:bg-gray-700 mx-1"></span>

    <!-- Language switcher desktop -->
    <div class="relative" id="lang-wrapper-desktop">
      <button
        id="dropdown-language"
        class="flex items-center gap-1 px-3 py-1.5 rounded-full font-semibold transition-colors
               text-gray-600 dark:text-gray-300
               hover:text-gray-900 dark:hover:text-white
               hover:bg-gray-100 dark:hover:bg-gray-800"
        aria-label="Select language"
      >
        {currentLocale.toUpperCase()}
        <svg class="w-3 h-3" fill="none" viewBox="0 0 10 6">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                stroke-width="2" d="m1 1 4 4 4-4"/>
        </svg>
      </button>
      <div
        id="language-menu"
        class="absolute hidden top-10 right-0 text-sm p-1 min-w-[5rem] rounded-xl
               border border-gray-200 dark:border-gray-700
               bg-white dark:bg-gray-900
               shadow-lg backdrop-blur-md z-50"
      >
        <ul>
          {languages.map((lang) => (
            <li>
              <a
                href={lang.href}
                class={`block px-3 py-2 rounded-lg cursor-pointer transition-colors
                        text-gray-700 dark:text-gray-200
                        hover:bg-gray-100 dark:hover:bg-gray-800
                        ${currentLocale === lang.locale
                          ? 'font-bold text-yellow-600 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/20'
                          : ''}`}
              >
                {lang.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <ThemeToggle />
  </nav>

  <!-- ── Mobile right controls ────────────────────────────────────────── -->
  <div class="md:hidden flex items-center gap-2">
    <ThemeToggle />
    <!-- Hamburger -->
    <button
      id="mobile-menu-btn"
      aria-label="Open menu"
      aria-expanded="false"
      class="p-2 rounded-xl
             text-gray-700 dark:text-gray-200
             transition"
    >
      <Menu />
    </button>
  </div>

</header>

<!-- ═══════════════════════════════════════════════════════════════════════
     MOBILE DRAWER OVERLAY
     Full-screen, works in both light and dark mode
     ═══════════════════════════════════════════════════════════════════════ -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-50 flex flex-col
         bg-white dark:bg-gray-950
         translate-x-full transition-transform duration-300 ease-in-out
         md:hidden"
  aria-hidden="true"
>
  <!-- Drawer header -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-gray-100 dark:border-gray-800">
    <span class="font-bold text-gray-900 dark:text-white tracking-wide">
      Andrés<span class="text-yellow-500">.</span>
    </span>
    <button
      id="mobile-menu-close"
      aria-label="Close menu"
      class="p-2 rounded-xl text-gray-600 dark:text-gray-300
             hover:bg-gray-100 dark:hover:bg-gray-800 transition"
    >
      <Close />
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex flex-col flex-1 px-4 py-6 gap-1 overflow-y-auto">
    {navItems.map((link) => (
      <a
        class="mobile-nav-link flex items-center gap-3 px-4 py-3.5 rounded-xl
               font-medium text-base transition-colors
               text-gray-700 dark:text-gray-200
               hover:bg-gray-100 dark:hover:bg-gray-800
               hover:text-gray-900 dark:hover:text-white"
        aria-label={link.label}
        href={link.url}
      >
        {link.title}
      </a>
    ))}

    <!-- Divider -->
    <div class="my-3 border-t border-gray-100 dark:border-gray-800"></div>

    <!-- Language switcher mobile -->
    <div class="px-4 py-2">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">
        Language
      </p>
      <div class="flex gap-2">
        {languages.map((lang) => (
          <a
            href={lang.href}
            onclick="localStorage.setItem('lang-redirected','1')"
            class={`flex-1 text-center py-2 rounded-xl text-sm font-semibold transition-colors
                    ${currentLocale === lang.locale
                      ? 'bg-yellow-400 dark:bg-yellow-500 text-gray-900'
                      : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'}`}
          >
            {lang.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Drawer footer -->
  <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-800">
    <p class="text-xs text-gray-400 dark:text-gray-600 text-center">
      andresvillarrealguti@gmail.com
    </p>
  </div>
</div>

<!-- Backdrop for mobile drawer -->
<div
  id="mobile-backdrop"
  class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm
         opacity-0 pointer-events-none transition-opacity duration-300
         md:hidden"
></div>

<script>
  document.addEventListener('astro:page-load', () => {

    // ── Smooth scroll compensating for fixed header ───────────────────────
    function scrollToSection(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      const header = document.querySelector('header');
      const headerH = header ? header.getBoundingClientRect().height + 12 : 72;
      const top = target.getBoundingClientRect().top + window.scrollY - headerH;
      window.scrollTo({ top, behavior: 'smooth' });
    }

    // ── Mobile drawer ─────────────────────────────────────────────────────
    const drawer   = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('mobile-backdrop');
    const openBtn  = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');

    function openDrawer() {
      drawer?.classList.remove('translate-x-full');
      drawer?.classList.add('translate-x-0');
      drawer?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      backdrop?.classList.add('opacity-100');
      openBtn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer?.classList.add('translate-x-full');
      drawer?.classList.remove('translate-x-0');
      drawer?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      backdrop?.classList.remove('opacity-100');
      openBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });

    // ── Nav link clicks (both desktop and mobile) ─────────────────────────
    const allNavLinks = document.querySelectorAll<HTMLAnchorElement>(
      'header nav a[aria-label], #mobile-drawer a[aria-label]'
    );

    allNavLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href') ?? '';
        const hashIndex = href.indexOf('#');
        if (hashIndex === -1) return;

        const sectionId  = href.slice(hashIndex + 1);
        const currentPath = window.location.pathname.replace(/\/$/, '');
        const linkPath    = href.slice(0, hashIndex).replace(/\/$/, '') || currentPath;

        if (linkPath && linkPath !== currentPath) return;

        e.preventDefault();

        const isDrawerOpen = drawer && !drawer.classList.contains('translate-x-full');

        if (isDrawerOpen) {
          // Close drawer first, then scroll after the 300ms CSS transition finishes
          closeDrawer();
          setTimeout(() => scrollToSection(sectionId), 320);
        } else {
          scrollToSection(sectionId);
        }

        history.pushState(null, '', `#${sectionId}`);
      });
    });

    // ── Mobile header background on scroll ───────────────────────────────
    const siteHeader = document.getElementById('site-header');
    const desktopNav = document.getElementById('desktop-nav');

    const SCROLLED_DESKTOP_CLASSES = [
      'bg-white/80', 'dark:bg-gray-900/80',
      'border', 'border-gray-200', 'dark:border-gray-700',
      'backdrop-blur-md', 'shadow-sm'
    ];
    const SCROLLED_MOBILE_CLASSES = [
      'bg-white/60', 'dark:bg-gray-950/60',
      'backdrop-blur-md', 'shadow-sm'
    ];
    const SCROLLED_HAMBURGUER_CLASSES = [
      'bg-white/80', 'dark:bg-gray-900/80',
      'border', 'border-gray-200', 'dark:border-gray-700',
      'backdrop-blur-md', 'shadow-sm', 'hover:bg-gray-100', 'dark:hover:bg-gray-800'
    ];

    function updateHeaderBg() {
      const scrolled = window.scrollY > 10;
      const isMobile = window.innerWidth < 768;

      // Desktop nav pill
      if (desktopNav) {
        if (scrolled) {
          // Scrolling down: enable transition first, then add classes
          desktopNav.classList.add('transition-all', 'duration-300');
          SCROLLED_DESKTOP_CLASSES.forEach(cls => desktopNav.classList.add(cls));
        } else {
          // Back to top: remove instantly, no transition flash
          desktopNav.classList.remove('transition-all', 'duration-300');
          SCROLLED_DESKTOP_CLASSES.forEach(cls => desktopNav.classList.remove(cls));
        }
      }

      // Mobile header bg
      if (siteHeader && isMobile) {
        SCROLLED_MOBILE_CLASSES.forEach(cls =>
          siteHeader.classList.toggle(cls, scrolled)
        );
      }

      // Mobile hamburger button
      if (openBtn && isMobile) {
        SCROLLED_HAMBURGUER_CLASSES.forEach(cls =>
          (openBtn as HTMLElement).classList.toggle(cls, scrolled)
        );
      }
    }

    window.addEventListener('scroll', updateHeaderBg, { passive: true });
    window.addEventListener('resize', updateHeaderBg, { passive: true });
    updateHeaderBg();
    const hash = window.location.hash.slice(1);
    if (hash && hash !== 'header-menu' && hash !== 'header-nav') {
      setTimeout(() => scrollToSection(hash), 120);
    } else if (!hash) {
      // Ensure page starts at the top on first load (no hash)
      window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
    }

    // ── Active section highlight ──────────────────────────────────────────
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const desktopLinks = document.querySelectorAll<HTMLElement>('header nav a[aria-label]');
    const mobileLinks  = document.querySelectorAll<HTMLElement>('#mobile-drawer a[aria-label]');

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;

          [...desktopLinks, ...mobileLinks].forEach((item) => {
            const isActive = item.getAttribute('aria-label') === id;
            item.classList.toggle('text-yellow-500', isActive);
            item.classList.toggle('dark:text-yellow-400', isActive);
            item.classList.toggle('bg-yellow-50', isActive);
            item.classList.toggle('dark:bg-yellow-900/20', isActive);
          });
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );

    sections.forEach((s) => sectionObserver.observe(s));

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        sectionObserver.disconnect();
      } else {
        sections.forEach((s) => sectionObserver.observe(s));
      }
    });

    // ── Desktop language dropdown ─────────────────────────────────────────
    const langMenu = document.getElementById('language-menu');
    const langBtn  = document.getElementById('dropdown-language');

    if (langBtn && langMenu) {
      const newBtn = langBtn.cloneNode(true) as HTMLElement;
      langBtn.parentNode?.replaceChild(newBtn, langBtn);

      document.addEventListener('click', () => langMenu.classList.remove('open'));
      newBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langMenu.classList.toggle('open');
      });

      langMenu.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => localStorage.setItem('lang-redirected', '1'));
      });
    }
  });
</script>

<style>
  /* Desktop language dropdown animation */
  #language-menu.open {
    display: block;
    animation: dropdown-in 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes dropdown-in {
    from { transform: scale(0.95) translateY(-4px); opacity: 0; }
    to   { transform: scale(1)    translateY(0);    opacity: 1; }
  }

  /* Desktop nav scroll animation handled via JS */

  /* Active nav link in desktop */
  .nav-link.active,
  .mobile-nav-link.active {
    color: rgb(234 179 8);
    background-color: rgb(254 252 232 / 0.6);
  }

  .dark .nav-link.active,
  .dark .mobile-nav-link.active {
    color: rgb(250 204 21);
    background-color: rgb(113 63 18 / 0.2);
  }
</style>
