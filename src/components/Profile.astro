---
import Linkedin from '../Icons/Linkedin.astro';
import Github from '../Icons/Github.astro';
import Social from '../components/Social.astro';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });

const graduationYear = 2024;
const currentYear = new Date().getFullYear();
const years = currentYear - graduationYear;

const description = i18n.PROFILE.description.replace('{years}', String(years));
---

<div class="w-full max-w-3xl mx-auto px-2 sm:px-4">

  <!-- Top row: avatar + action buttons -->
  <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 mb-6">

    <a href="#about" class="group shrink-0">
      <img
        src="/me3.jpg"
        alt="Andres Villarreal"
        class="rounded-full shadow-xl w-20 h-20 sm:w-28 sm:h-28
               transition-transform duration-300 group-hover:scale-105"
      />
    </a>

    <div class="flex flex-wrap justify-center sm:justify-start items-center gap-3">
      <!-- Resume button with halo aurora effect -->
      <div id="halo-btn" class="relative flex items-center justify-center">

        <!-- Aurora glow (outermost, blurry) -->
        <div class="halo-layer aurora-glow"></div>
        <!-- Outer rings -->
        <div class="halo-layer outer-ring"></div>
        <div class="halo-layer outer-ring"></div>
        <div class="halo-layer outer-ring"></div>
        <!-- Inner glow -->
        <div class="halo-layer inner-glow"></div>
        <!-- Main border -->
        <div class="halo-layer main-border"></div>

        <!-- The actual button -->
        <a
          href="/docs/cv2024.pdf"
          download="cv2024.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-xl
                 font-medium text-sm sm:text-base select-none
                 halo-btn-inner"
        >
          <svg class="download-icon size-4 sm:size-5" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {i18n.PROFILE.resume}
        </a>
      </div>
    </div>
  </div>

  <!-- Heading -->
  <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight
             text-gray-900 dark:text-white text-center sm:text-left">
    {i18n.PROFILE.greeting}<span class="animate-wave">👋</span>
  </h1>

  <!-- Description -->
  <p class="mt-4 sm:mt-6 text-base sm:text-lg lg:text-xl
            text-gray-700 dark:text-gray-300 leading-relaxed
            text-center sm:text-left"
     id="profile-description"
     data-graduation-year="2024"
     data-template={i18n.PROFILE.description}>
    {description}
  </p>

  <!-- Social links -->
  <nav class="flex justify-center sm:justify-start gap-3 sm:gap-4 mt-6 sm:mt-8 flex-wrap">
    <Social
      href="https://www.linkedin.com/in/avillarrealg/"
      class="flex items-center gap-2 text-sm sm:text-base
             text-gray-700 dark:text-gray-200
             border-gray-300 dark:border-gray-600
             hover:text-blue-600 dark:hover:text-blue-400
             hover:border-blue-400 dark:hover:border-blue-500 transition"
    >
      <Linkedin class="size-4 sm:size-5" />
      LinkedIn
    </Social>

    <Social
      href="https://github.com/AndresVGu"
      class="flex items-center gap-2 text-sm sm:text-base
             text-gray-700 dark:text-gray-200
             border-gray-300 dark:border-gray-600
             hover:text-gray-900 dark:hover:text-white
             hover:border-gray-500 dark:hover:border-gray-400 transition"
    >
      <Github class="size-4 sm:size-5" />
      GitHub
    </Social>
  </nav>
</div>

<style>
  .animate-wave {
    display: inline-block;
    transform-origin: 70% 70%;
    animation: wave 1.5s infinite;
  }
  @keyframes wave {
    0%, 60%, 100% { transform: rotate(0deg); }
    20%  { transform: rotate(15deg); }
    40%  { transform: rotate(-10deg); }
  }

  /* ── HALO BUTTON ─────────────────────────────────────────── */
  #halo-btn {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Button inner — adapts to light/dark */
  .halo-btn-inner {
    background: linear-gradient(160deg, #1c1a2e, #0f0e1a, #1a1c2e);
    color: #f1f5f9;
  }
  /* Light mode: slightly lighter dark bg so halo still pops */
  :root:not(.dark) .halo-btn-inner {
    background: linear-gradient(160deg, #f8f7ff, #f1f0fa, #f5f4fe);
    color: #1e1b4b;
  }

  /* All halo layers share this base */
  .halo-layer {
    position: absolute;
    overflow: hidden;
    border-radius: 14px;
    z-index: 0;
  }

  .halo-layer::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 700px;
    height: 700px;
    background-repeat: no-repeat;
    background-position: 0 0;
  }

  /* ── Aurora glow — outermost, wide soft bloom ── */
  .aurora-glow {
    inset: -36px -28px;
    filter: blur(22px);
    opacity: 0.55;
  }
  /* Dark mode: full intensity */
  .aurora-glow::before {
    background-image: conic-gradient(
      transparent,
      #402fb5 4%,
      transparent 20%,
      transparent 48%,
      #cf30aa 58%,
      transparent 74%,
      transparent 100%
    );
    animation: halo-spin 7s linear infinite;
  }
  /* Light mode: soft pastel bloom, fill matches light bg */
  :root:not(.dark) .aurora-glow {
    opacity: 0.5;
    filter: blur(20px);
  }
  :root:not(.dark) .aurora-glow::before {
    background-image: conic-gradient(
      #f1f0fa,
      #c4b5fd 4%,   /* violet-300 */
      #f1f0fa 20%,
      #f1f0fa 48%,
      #f9a8d4 58%,  /* pink-300 */
      #f1f0fa 74%,
      #f1f0fa 100%
    );
  }

  /* ── Outer rings ── */
  .outer-ring {
    inset: -8px -8px;
    filter: blur(2.5px);
  }
  .outer-ring::before {
    background-image: conic-gradient(
      rgba(0,0,0,0),
      #18116a,
      rgba(0,0,0,0) 10%,
      rgba(0,0,0,0) 50%,
      #6e1b60,
      rgba(0,0,0,0) 60%
    );
    animation: halo-spin 4s linear infinite;
  }
  .outer-ring:nth-child(3)::before {
    animation-duration: 4.8s;
  }
  .outer-ring:nth-child(4)::before {
    animation-duration: 5.6s;
  }
  /* Light mode: pastel outer rings, fill matches light bg */
  :root:not(.dark) .outer-ring::before {
    background-image: conic-gradient(
      #f1f0fa,
      #a78bfa 0%,   /* violet-400 */
      #ddd6fe 6%,   /* violet-200 */
      #f1f0fa 14%,
      #f1f0fa 50%,
      #f0abfc 56%,  /* fuchsia-300 */
      #fae8ff 62%,  /* fuchsia-100 */
      #f1f0fa 70%
    );
  }
  :root:not(.dark) .outer-ring:nth-child(3)::before {
    background-image: conic-gradient(
      #f1f0fa,
      #c4b5fd 3%,
      #f1f0fa 12%,
      #f1f0fa 50%,
      #f5d0fe 58%,
      #f1f0fa 68%
    );
  }
  :root:not(.dark) .outer-ring:nth-child(4)::before {
    background-image: conic-gradient(
      #f1f0fa,
      #ede9fe 4%,
      #f1f0fa 11%,
      #f1f0fa 52%,
      #fdf4ff 60%,
      #f1f0fa 70%
    );
  }

  /* ── Inner glow ── */
  .inner-glow {
    inset: -4px -4px;
    filter: blur(1.5px);
  }
  .inner-glow::before {
    filter: brightness(1.6);
    background-image: conic-gradient(
      rgba(0,0,0,0) 0%,
      #a099d8,
      rgba(0,0,0,0) 8%,
      rgba(0,0,0,0) 50%,
      #dfa2da,
      rgba(0,0,0,0) 58%
    );
    animation: halo-spin 3.2s linear infinite;
  }
  /* Light mode: soft inner glow */
  :root:not(.dark) .inner-glow {
    opacity: 0.9;
  }
  :root:not(.dark) .inner-glow::before {
    filter: brightness(1.1);
    background-image: conic-gradient(
      #f1f0fa 0%,
      #8b5cf6 3%,   /* violet-500 */
      #c4b5fd 6%,   /* violet-300 */
      #f1f0fa 12%,
      #f1f0fa 50%,
      #d946ef 56%,  /* fuchsia-500 */
      #f0abfc 60%,  /* fuchsia-300 */
      #f1f0fa 66%
    );
  }

  /* ── Main border — sharpest, almost no blur ── */
  .main-border {
    inset: -1.5px -1.5px;
    filter: blur(0px);
  }
  .main-border::before {
    filter: brightness(1.3);
    background-image: conic-gradient(
      transparent,
      #402fb5 5%,
      transparent 14%,
      transparent 50%,
      #cf30aa 60%,
      transparent 64%
    );
    animation: halo-spin 2.8s linear infinite;
  }
  /* Light mode: sharp border with light bg fill */
  :root:not(.dark) .main-border {
    opacity: 1;
  }
  :root:not(.dark) .main-border::before {
    filter: brightness(1.1);
    background-image: conic-gradient(
      #f1f0fa,
      #7c3aed 5%,   /* violet-600 */
      #f1f0fa 14%,
      #f1f0fa 50%,
      #a21caf 60%,  /* fuchsia-700 */
      #f1f0fa 64%
    );
  }

  @keyframes halo-spin {
    from { transform: translate(-50%, -50%) rotate(0deg);   }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── HOVER ─────────────────────────────────────────────────── */

  /* Scale up the whole button */
  #halo-btn:hover .halo-btn-inner {
    transform: scale(1.04);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .halo-btn-inner {
    transition: transform 0.2s ease;
  }

  /* Boost aurora opacity on hover */
  #halo-btn:hover .aurora-glow {
    opacity: 0.75;
    transition: opacity 0.3s ease;
  }
  :root:not(.dark) #halo-btn:hover .aurora-glow {
    opacity: 0.32;
  }

  /* Boost outer rings on hover */
  #halo-btn:hover .outer-ring {
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  /* Download icon bounce on hover */
  #halo-btn:hover .download-icon {
    animation: icon-bounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes icon-bounce {
    0%   { transform: translateY(0);    }
    40%  { transform: translateY(4px);  }
    70%  { transform: translateY(-2px); }
    100% { transform: translateY(0);    }
  }
</style>

<script is:inline>
  (function () {
    const el = document.getElementById('profile-description');
    if (!el) return;
    const graduationYear = parseInt(el.dataset.graduationYear, 10);
    const years = new Date().getFullYear() - graduationYear;
    const template = el.dataset.template;
    if (template) el.textContent = template.replace('{years}', years);
  })();
</script>
