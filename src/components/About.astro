---
import Photocard from './photocards/photocard.astro';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const t = i18n.ABOUT;

const graduationYear = 2024;
const years = new Date().getFullYear() - graduationYear;

const p1 = t.p1.replace('{years}', String(years));
const p2 = t.p2.replace('{years}', String(years));
const p3 = t.p3.replace('{years}', String(years));

const techs = [
  'Java', 'Spring Boot', 'Linux', 'Python', '.NET Core', 'AWS',
  'Docker', 'Kubernetes', 'SQL', 'PostgreSQL', 'JavaScript', 'Angular', 'Astro',
];
---

<article class="grid grid-cols-1 gap-8 lg:gap-12 lg:grid-cols-2 items-start text-gray-700 dark:text-gray-300">

  <!-- LEFT -->
  <div class="space-y-6">

    <!-- Tagline -->
    <p class="text-lg font-semibold text-yellow-500 dark:text-yellow-200">
      {t.tagline}
    </p>

    <!-- Description -->
    <div class="space-y-4 text-pretty
                [&>p>strong]:font-mono
                [&>p>strong]:text-gray-900
                dark:[&>p>strong]:text-yellow-100">
      <p set:html={p1} />
      <p set:html={p2} />
      <p set:html={p3} />
    </div>

    <!-- Tech Stack -->
    <div>
      <p class="mb-2 text-sm font-semibold text-gray-500 dark:text-gray-400">
        {t.techStack}
      </p>
      <div class="flex flex-wrap gap-3 text-xs">
        {techs.map((tech) => (
          <span
            class="group relative px-3 py-1 rounded-md border
                   border-black/10 dark:border-white/10
                   bg-black/5 dark:bg-white/5
                   transition-all duration-300 ease-out
                   hover:-translate-y-1 hover:scale-105
                   hover:border-cyan-500/60 dark:hover:border-cyan-400/40
                   hover:bg-gradient-to-r
                   hover:from-cyan-500/20 hover:to-purple-500/20
                   dark:hover:from-cyan-500/10 dark:hover:to-purple-500/10
                   cursor-default overflow-hidden"
          >
            <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-300
                         bg-gradient-to-r from-cyan-500/20 to-purple-500/20
                         dark:from-cyan-400/20 dark:to-purple-500/20 blur-md"></span>
            <span class="relative z-10 tracking-wide text-gray-800 dark:text-gray-200
                         group-hover:text-black dark:group-hover:text-white">
              {tech}
            </span>
          </span>
        ))}
      </div>
    </div>

    <!-- Strengths -->
    <div class="grid grid-cols-2 gap-3 text-sm text-gray-700 dark:text-gray-300">
      <div>{t.strengths.backend}</div>
      <div>{t.strengths.cloud}</div>
      <div>{t.strengths.data}</div>
      <div>{t.strengths.linux}</div>
    </div>

    <!-- Focus -->
    <p class="text-sm text-gray-500 dark:text-gray-400">{t.focus}</p>

  </div>

  <!-- RIGHT (BENTO) -->
  <div class="grid grid-cols-2 gap-3 md:gap-4">

    <!-- Image -->
    <div class="col-span-2 group relative">
      <Photocard
        src="/me3.jpg"
        alt="Andres Villarreal"
        badgeText={`🚀 ${t.cards.focused}`}
      />
    </div>

    <!-- Card 1 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">
      <p class="font-semibold mb-1 text-gray-800 dark:text-gray-100">{t.cards.focused}</p>
      {t.cards.focusedItems.map((item) => (
        <p class="text-gray-600 dark:text-gray-400">{item}</p>
      ))}
    </div>

    <!-- Card 2 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">
      <p class="font-semibold mb-1 text-gray-800 dark:text-gray-100">{t.cards.location}</p>
      <p class="text-gray-600 dark:text-gray-400">{t.cards.locationValue}</p>
    </div>

    <!-- Card 3 -->
    <div class="col-span-2 rounded-2xl p-4 text-sm
                bg-gradient-to-r from-cyan-500/10 to-purple-500/10
                border border-cyan-500/20
                hover:scale-[1.02] transition">
      <p class="font-semibold mb-1 text-gray-800 dark:text-gray-100">{t.cards.interests}</p>
      {t.cards.interestItems.map((item) => (
        <p class="text-gray-700 dark:text-gray-300">{item}</p>
      ))}
    </div>

  </div>

</article>

<script>
  import '../scripts/about';
</script>
