---
import ProjectLayout from '@/layouts/ProjectLayout.astro';
import { getI18N } from '@/i18n';

export async function getStaticPaths() {
  const i18n = getI18N({ currentLocale: 'fr' });
  return i18n.PROJECTS.map((project) => ({
    params: { slug: (project as any).slug },
    props: { slug: (project as any).slug },
  }));
}

const { slug } = Astro.params;
const i18n = getI18N({ currentLocale: 'fr' });

const PROJECT_IMAGES: Record<string, string> = {
  'toughbook-autoinstaller': '/photocards/laptops.webp',
  'nbd-landscaping':    '/projects/bg.webp',
  'cities-api':         '/projects/api2.webp',
  'spotify-clone':      '/projects/spo.webp',
  'emmas-small-engines':'/projects/emma.webp',
  'vitgreen':           '/projects/vit.webp',
  'v12-magazine':       '/projects/v12Magazinea.webp',
};

const project = i18n.PROJECTS.find((p) => (p as any).slug === slug);
if (!project) return Astro.redirect('/fr/');

const p = project as any;
---

<ProjectLayout
  currentLocale="fr"
  title={p.title}
  description={p.description}
  image={PROJECT_IMAGES[slug!] ?? ''}
  subtitle={p.subtitle}
  stack={p.stack ?? []}
  liveUrl={p.liveUrl}
  codeUrl={p.codeUrl}
  docsUrl={p.docsUrl ?? null}
  languages={p.languages ?? []}
>
  <Fragment set:html={p.detailDescription} />
</ProjectLayout>
