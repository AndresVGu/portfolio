---
import { getI18N } from '@/i18n';
import CarouselModal from './CarouselModal.astro';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });

const PROJECT_IMAGES = [
  '/photocards/laptops.webp',
  '/projects/bg.webp',
  '/projects/api2.webp',
  '/projects/spo.webp',
  '/projects/emma.webp',
  '/projects/vit.webp',
  '/projects/v12Magazinea.webp',
];

const projects = i18n.PROJECTS.map((p, i) => ({
  ...p,
  image: PROJECT_IMAGES[i] ?? '',
}));
---

<div class="relative w-full" data-carousel-root>

  <!-- Left arrow — just outside the left edge of the max-w-5xl track -->
  <button
    data-carousel-btn-left
    aria-label={i18n.CAROUSEL.scrollLeft}
    aria-disabled="true"
    disabled
    class="hidden sm:flex absolute z-40 top-1/2 -translate-y-1/2
           left-[max(0.25rem,calc((100%-64rem)/2-3rem))]
           size-9 sm:size-10 items-center justify-center rounded-full
           bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm
           text-gray-600 dark:text-gray-400
           shadow-md ring-1 ring-black/5 dark:ring-white/10
           opacity-0 pointer-events-none
           hover:bg-white dark:hover:bg-gray-700
           transition-all duration-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-5 sm:size-6" fill="none"
         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <!-- Right arrow — just outside the right edge of the max-w-5xl track -->
  <button
    data-carousel-btn-right
    aria-label={i18n.CAROUSEL.scrollRight}
    class="hidden sm:flex absolute z-40 top-1/2 -translate-y-1/2
           right-[max(0.25rem,calc((100%-64rem)/2-3rem))]
           size-9 sm:size-10 items-center justify-center rounded-full
           bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm
           text-gray-600 dark:text-gray-400
           shadow-md ring-1 ring-black/5 dark:ring-white/10
           hover:bg-white dark:hover:bg-gray-700
           transition-all duration-200
           carousel-arrow-hint"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-5 sm:size-6" fill="none"
         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Track -->
  <div
    data-carousel-track
    role="region"
    aria-label={i18n.CAROUSEL.regionLabel}
    class="mx-auto max-w-5xl overflow-x-scroll overscroll-x-auto scroll-smooth
           snap-x snap-mandatory py-6 sm:py-10 md:py-14 lg:py-16
           carousel-hide-scrollbar"
  >
    <div class="flex flex-row justify-start gap-4 sm:gap-5 lg:gap-6 px-4 sm:px-8 lg:px-10 py-4 w-max">

      {projects.map((project, i) => (
        <div
          class="carousel-card-animate group flex-shrink-0 snap-start flex flex-col
                 w-[75vw] max-w-[280px] sm:w-[320px] sm:max-w-none md:w-[360px] lg:w-[420px]
                 cursor-pointer"
          data-carousel-card
          data-index={i}
          data-description={project.description}
          data-detail-description={(project as any).detailDescription ?? project.description}
          data-subtitle={project.subtitle}
          data-slug={(project as any).slug ?? ''}
          data-stack={JSON.stringify((project as any).stack ?? [])}
          data-image={project.image}
          data-live-url={(project as any).liveUrl ?? ''}
          data-code-url={(project as any).codeUrl ?? ''}
          style={`--card-delay: ${0.15 * i}s`}
        >
          <!-- Image -->
          <div class="relative w-full overflow-hidden rounded-2xl aspect-[3/4]
                      bg-gray-100 dark:bg-neutral-800
                      ring-1 ring-black/5 dark:ring-white/10
                      transition-transform duration-300 ease-out group-hover:scale-[1.02]">
            <div class="pointer-events-none absolute inset-0 z-10 opacity-0 group-hover:opacity-100
                        transition-opacity duration-300 bg-black/10 dark:bg-white/5" />
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 z-0 h-full w-full object-cover
                     transition-all duration-500 blur-sm group-hover:blur-0 group-hover:scale-105"
              data-carousel-img
            />
          </div>

          <!-- Caption -->
          <div class="pt-3 pb-1 px-1">
            <h3 class="text-sm sm:text-base font-semibold text-neutral-900 dark:text-white leading-snug">
              <span class="font-bold">{project.title}.</span>
              {' '}
              <span class="font-normal text-neutral-600 dark:text-neutral-400">{project.description}</span>
            </h3>
          </div>
        </div>
      ))}

      <div class="flex-shrink-0 w-4 sm:w-8 md:w-12 lg:w-16" aria-hidden="true" />
    </div>
  </div>

  <!-- Modal (separate component) -->
  <CarouselModal currentLocale={currentLocale} />

</div>

<style>
  .carousel-hide-scrollbar { scrollbar-width: none; }
  .carousel-hide-scrollbar::-webkit-scrollbar { display: none; }

  .carousel-card-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: cardFadeIn 0.5s ease-out forwards;
    animation-delay: var(--card-delay, 0s);
  }
  @keyframes cardFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Gentle pulse on the right arrow on first load — continuous until user scrolls */
  .carousel-arrow-hint {
    animation: arrowPulse 1.8s ease-in-out 1s infinite;
  }
  @keyframes arrowPulse {
    0%, 100% {
      transform: translateY(-50%) scale(1);
      box-shadow: 0 0 0 0 rgba(200, 200, 200, 0.4);
    }
    50% {
      transform: translateY(-50%) scale(1.1);
      box-shadow: 0 0 12px 4px rgba(200, 200, 200, 0.3);
    }
  }
</style>

<script>
  import '@/scripts/carousel';
</script>
