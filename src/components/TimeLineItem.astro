---
import LinkInLine from '../components/LinkInLine.astro';

const { startDate, endDate, title, company, description, list, link } = Astro.props;
---

<div class="timeline-item step relative pb-12 md:pb-20">

  <!-- Vertical line — runs full height of the item -->
  <div class="timeline-line absolute left-3 md:left-0 top-0 w-[2px] md:w-[3px] h-full
              bg-black/10 dark:bg-white/10 overflow-hidden">
    <div class="progress bg-gradient-to-b from-yellow-400 via-cyan-400 to-transparent
                w-full h-0 transition-all duration-500"></div>
  </div>

  <!-- DOT -->
  <span class="dot absolute left-[5px] md:left-[-5px] top-2
               w-4 h-4 rounded-full
               bg-black/30 dark:bg-white/30
               transition-all duration-300 z-10"></span>

  <!-- Content — always indented from the line -->
  <div class="pl-10 md:pl-0 md:ml-8 grid md:grid-cols-5 md:gap-10">

    <!-- LEFT: title / company / dates -->
    <div class="md:col-span-2 mb-3 md:mb-0">
      <div class="content-left opacity-0 translate-y-10 transition-all duration-500">
        <h3 class="text-xl md:text-2xl font-bold text-black dark:text-white">{title}</h3>
        <h4 class="text-base md:text-lg text-gray-700 dark:text-gray-300">{company}</h4>
        <p class="text-xs md:text-sm text-gray-500 dark:text-gray-400 mt-1">
          {startDate} — {endDate}
        </p>
      </div>
    </div>

    <!-- RIGHT: description card -->
    <div class="md:col-span-3">
      <div class="card content-right opacity-0 translate-y-10 relative p-4 md:p-6
                  rounded-2xl bg-black/5 dark:bg-white/5
                  border border-black/10 dark:border-white/10
                  backdrop-blur-xl overflow-hidden transition-all duration-500">

        <div class="glow pointer-events-none absolute inset-0 opacity-0 transition duration-300"></div>

        <p class="text-sm md:text-base text-gray-800 dark:text-gray-200">{description}</p>
        <div class="mt-2 text-xs md:text-sm text-gray-600 dark:text-gray-400">{list}</div>

        {link && (
          <div class="mt-4">
            <LinkInLine href={link}>See more →</LinkInLine>
          </div>
        )}
      </div>
    </div>

  </div>
</div>

<script>
  import '../scripts/timeLineItem'
</script>

<style>
  .dot-pop {
    animation: pop 0.35s ease;
  }
  @keyframes pop {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }
</style>
