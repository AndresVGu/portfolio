    text-lg font-medium text-blue-600 dark:text-yellow-300 
    dark:hover:text-yellow-300 hover:text-yellow-700"
    data-pswp-width="2000"
    data-pswp-height="1345"    
    >
        {p[0].gallery}{" "}
        <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 icon icon-tabler icon-tabler-chevron-right"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        stroke-linecap="round"
         stroke-linejoin="round"
        >
        <>
        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
        <path d="M9 6l6 6l-6 6" />
        </>  
        </svg>
        
    
    </a>
    <!--Other Images -->              
    {
        Array.from({length:8}).map((_, i) =>(
            <a
            class="group rounded-xl hover:scale-105 
            transition-all relative"
            href={`/projects/NBD/image-${i+2}.webp`}
            data-pswp-width="2000"
            data-pswp-height="1345"    
            target="_blank"
            >
                
            </a>
        )) 
    }
                </div>
               
            </div>
            <!-- Modal footer -->
            <div class="flex items-center p-4 md:p-5 border-t border-gray-200 rounded-b dark:border-gray-600 gap-2">
                <LinkButton href="https://github.com/AndresVGu/NBD2024Project">
