---
import '@fontsource-variable/onest';
import '@/styles/base.css';
import ProjectHeader from '@/components/ProjectHeader.astro';
import Footer from '@/components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
  title: string;
  description: string;
  image: string;
  subtitle: string;
  stack: string[];
  languages?: { name: string; percent: number; color: string }[];
  liveUrl?: string | null;
  codeUrl?: string | null;
  docsUrl?: string | null;
}

const {
  currentLocale = 'en',
  title,
  description,
  image,
  subtitle,
  stack,
  languages = [],
  liveUrl,
  codeUrl,
  docsUrl,
} = Astro.props;

const i18n = getI18N({ currentLocale });
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/main_icons/iconb.png" />
    <link rel="apple-touch-icon" href="/main_icons/icona.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#030712" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Andrés Villarreal</title>
    <link rel="canonical" href={`https://andresvillarreal.netlify.app${Astro.url.pathname}`} />
    <ViewTransitions />

    <!-- Apply dark/light theme before paint -->
    <script is:inline>
      (function () {
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        const pref = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = pref === 'dark' || (pref === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      })();
      document.addEventListener('astro:after-swap', function () {
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        const pref = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = pref === 'dark' || (pref === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      });
    </script>
  </head>

  <body class="text-black dark:text-white">
    <!-- Same background gradient as main layout -->
    <div class="fixed top-0 bottom-0 left-0 right-0 z-[-2] w-full bg-gray-50 dark:bg-gray-950
                bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(217,216,255,0.5),rgba(255,255,255,0.9))]
                dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]">
    </div>

    <ProjectHeader currentLocale={currentLocale} />

    <main class="px-4 sm:px-6 max-w-6xl mx-auto pt-24 sm:pt-28 pb-12 sm:pb-20">

      <!-- Hero image -->
      <div class="w-full max-w-3xl mx-auto aspect-[3/2] rounded-2xl overflow-hidden
                  bg-gray-100 dark:bg-neutral-800
                  ring-1 ring-black/5 dark:ring-white/10 mb-8">
        <img src={image} alt={title} class="w-full h-full object-cover" />
      </div>

      <!-- Subtitle + title -->
      <div class="max-w-3xl mx-auto">
        <p class="text-xs sm:text-sm font-semibold uppercase tracking-widest
                  text-gray-400 dark:text-gray-500 mb-2">
          {subtitle}
        </p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold
                   text-neutral-900 dark:text-white leading-tight mb-4">
          {title}
        </h1>

        <!-- Tech stack pills -->
        <div class="flex flex-wrap gap-2 mb-4">
          {stack.map(tech => (
            <span class="inline-block rounded-full bg-gray-100 dark:bg-neutral-800
                         px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300">
              {tech}
            </span>
          ))}
        </div>

        <!-- Languages bar -->
        {languages.length > 0 && (
          <div class="mb-8">
            <div class="w-full h-2.5 rounded-full overflow-hidden flex">
              {languages.map(l => (
                <div style={`width:${l.percent}%; background-color:${l.color};`} title={`${l.name} ${l.percent}%`}></div>
              ))}
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
              {languages.map(l => (
                <span class="flex items-center gap-1.5 text-xs text-gray-600 dark:text-gray-400">
                  <span class="size-2.5 rounded-full" style={`background-color:${l.color};`}></span>
                  <strong>{l.name}</strong> {l.percent}%
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3 mb-10">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-full bg-neutral-900 dark:bg-white
                      px-5 py-2.5 text-sm font-semibold
                      text-white dark:text-neutral-900
                      hover:bg-neutral-700 dark:hover:bg-gray-100
                      transition-colors duration-200">
              {i18n.CAROUSEL.liveDemo}
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
                   viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
          {codeUrl && (
            <a href={codeUrl} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-full
                      border border-gray-300 dark:border-gray-600
                      px-5 py-2.5 text-sm font-semibold
                      text-neutral-700 dark:text-gray-200
                      hover:bg-gray-100 dark:hover:bg-neutral-800
                      transition-colors duration-200">
              {i18n.CAROUSEL.sourceCode}
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
                   viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </a>
          )}
          {docsUrl && (
            <a href={docsUrl} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-full
                      border border-gray-300 dark:border-gray-600
                      px-5 py-2.5 text-sm font-semibold
                      text-neutral-700 dark:text-gray-200
                      hover:bg-gray-100 dark:hover:bg-neutral-800
                      transition-colors duration-200">
              {i18n.CAROUSEL.fullDocs}
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
                   viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Divider -->
      <hr class="max-w-3xl mx-auto border-gray-200 dark:border-neutral-800 mb-10" />

      <!-- Two-column layout: TOC + Content -->
      <div class="relative lg:grid lg:grid-cols-[220px_1fr] lg:gap-10 max-w-5xl mx-auto">

        <!-- TOC sidebar (desktop only, sticky) -->
        <aside class="hidden lg:block">
          <nav
            id="project-toc"
            class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto
                   pr-4 border-r border-gray-200 dark:border-neutral-800"
          >
            <p class="text-xs font-semibold uppercase tracking-widest
                      text-gray-400 dark:text-gray-500 mb-3">
              On this page
            </p>
            <ul id="toc-list" class="space-y-1 text-sm">
              <!-- Populated by JS from h2 headings -->
            </ul>
          </nav>
        </aside>

        <!-- Main content -->
        <article
          id="project-content"
          class="project-article prose prose-neutral dark:prose-invert max-w-none"
        >
          <slot />
        </article>
      </div>

    </main>

    <Footer currentLocale={currentLocale} />

    <!-- Project page interactions + Image lightbox -->
    <script>
      import '@/scripts/project-page';

      document.addEventListener('astro:page-load', () => {
        const content = document.getElementById('project-content');
        if (!content) return;

        // Collect all zoomable images (skip GIFs)
        const allImages: string[] = [];
        content.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
          const src = img.getAttribute('src') ?? '';
          if (src.toLowerCase().endsWith('.gif')) return;
          allImages.push(src);

          img.style.cursor = 'zoom-in';
          img.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            openLightbox(allImages.indexOf(src));
          });
        });

        // ── Overview gallery slider ────────────────────────────────────────
        const galleryContainer = content.querySelector('.project-overview-gallery');
        if (galleryContainer) {
          const imgs = galleryContainer.querySelectorAll<HTMLImageElement>('img');
          const prevBtn = galleryContainer.querySelector<HTMLButtonElement>('[data-gal-prev]');
          const nextBtn = galleryContainer.querySelector<HTMLButtonElement>('[data-gal-next]');
          const counter = galleryContainer.querySelector<HTMLElement>('[data-gal-counter]');
          if (imgs.length > 1 && prevBtn && nextBtn && counter) {
            let idx = 0;
            const total = imgs.length;
            imgs.forEach((img, i) => { if (i !== 0) img.style.display = 'none'; });

            function show(i: number) {
              imgs.forEach((img, j) => { img.style.display = j === i ? 'block' : 'none'; });
              counter!.textContent = `${i + 1} / ${total}`;
              prevBtn!.disabled = i === 0;
              prevBtn!.style.opacity = i === 0 ? '0.3' : '1';
              nextBtn!.disabled = i === total - 1;
              nextBtn!.style.opacity = i === total - 1 ? '0.3' : '1';
            }
            prevBtn.addEventListener('click', (e) => { e.stopPropagation(); if (idx > 0) show(--idx); });
            nextBtn.addEventListener('click', (e) => { e.stopPropagation(); if (idx < total - 1) show(++idx); });
            show(0);
          }
        }

        // ── Lightbox with navigation ───────────────────────────────────────
        let overlay = document.getElementById('img-lightbox') as HTMLDivElement | null;
        let currentIdx = 0;

        if (!overlay) {
          overlay = document.createElement('div');
          overlay.id = 'img-lightbox';
          overlay.className = 'fixed inset-0 z-[9999] hidden items-center justify-center bg-black/90 backdrop-blur-sm';
          overlay.innerHTML = `
            <button data-lb-prev class="absolute left-4 top-1/2 -translate-y-1/2 z-10 flex size-10 items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition">
              <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <img class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg shadow-2xl cursor-default" />
            <button data-lb-next class="absolute right-4 top-1/2 -translate-y-1/2 z-10 flex size-10 items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition">
              <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
            <button data-lb-close class="absolute top-4 right-4 z-10 flex size-8 items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition">
              <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <span data-lb-counter class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm text-white/70 tabular-nums"></span>
          `;
          document.body.appendChild(overlay);

          // Close
          overlay.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).tagName === 'IMG') return;
            if ((e.target as HTMLElement).closest('button')) return;
            closeLightbox();
          });
          overlay.querySelector('[data-lb-close]')!.addEventListener('click', closeLightbox);
          overlay.querySelector('[data-lb-prev]')!.addEventListener('click', () => navigate(-1));
          overlay.querySelector('[data-lb-next]')!.addEventListener('click', () => navigate(1));

          document.addEventListener('keydown', (e) => {
            if (overlay!.classList.contains('hidden')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') navigate(-1);
            if (e.key === 'ArrowRight') navigate(1);
          });
        }

        function openLightbox(idx: number) {
          currentIdx = idx;
          showImage();
          overlay!.classList.remove('hidden');
          overlay!.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
          overlay!.classList.add('hidden');
          overlay!.classList.remove('flex');
          document.body.style.overflow = '';
        }

        function navigate(dir: number) {
          const newIdx = currentIdx + dir;
          if (newIdx < 0 || newIdx >= allImages.length) return;
          currentIdx = newIdx;
          showImage();
        }

        function showImage() {
          const img = overlay!.querySelector('img')!;
          img.src = allImages[currentIdx];
          const counterEl = overlay!.querySelector('[data-lb-counter]')!;
          counterEl.textContent = `${currentIdx + 1} / ${allImages.length}`;
          const prevBtn = overlay!.querySelector('[data-lb-prev]') as HTMLElement;
          const nextBtn = overlay!.querySelector('[data-lb-next]') as HTMLElement;
          prevBtn.style.opacity = currentIdx === 0 ? '0.3' : '1';
          nextBtn.style.opacity = currentIdx === allImages.length - 1 ? '0.3' : '1';
        }
      });
    </script>

    <style is:global>
      /* Project article typography */
      .project-article h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-top: 3.5rem;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        scroll-margin-top: 6rem;
        line-height: 1.2;
      }
      .dark .project-article h2 {
        border-bottom-color: rgba(255, 255, 255, 0.1);
      }
      @media (min-width: 640px) {
        .project-article h2 { font-size: 2rem; }
      }

      .project-article h3 {
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        scroll-margin-top: 6rem;
        line-height: 1.3;
      }
      @media (min-width: 640px) {
        .project-article h3 { font-size: 1.5rem; }
      }

      .project-article p {
        margin-top: 1rem;
        margin-bottom: 1rem;
        line-height: 1.75;
        color: rgb(55, 65, 81);
      }
      .dark .project-article p {
        color: rgb(209, 213, 219);
      }

      .project-article ul,
      .project-article ol {
        margin-top: 1rem;
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }
      .project-article li {
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
        color: rgb(55, 65, 81);
      }
      .dark .project-article li {
        color: rgb(209, 213, 219);
      }

      .project-article code:not(pre code) {
        font-size: 0.875rem;
        background: rgb(243, 244, 246);
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
      }
      .dark .project-article code:not(pre code) {
        background: rgb(38, 38, 38);
      }
      .project-article code::before,
      .project-article code::after {
        content: none !important;
      }

      .project-article pre {
        background: rgb(243, 244, 246);
        border-radius: 0.75rem;
        padding: 1.25rem;
        font-size: 0.875rem;
        overflow-x: auto;
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
        color: rgb(31, 41, 55);
        border: 1px solid rgba(0, 0, 0, 0.06);
        max-width: 100%;
        word-wrap: break-word;
      }
      .dark .project-article pre {
        background: rgb(10, 10, 10);
        color: rgb(229, 231, 235);
        border-color: rgba(255, 255, 255, 0.06);
      }

      .project-article img {
        border-radius: 0.75rem;
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.05);
        max-width: 100%;
        height: auto;
      }
      .dark .project-article img {
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1);
      }

      /* Prevent overflow on mobile */
      .project-article {
        overflow-wrap: break-word;
        word-break: break-word;
      }
      .project-article * {
        max-width: 100%;
      }
      .project-article pre code {
        font-size: 0.75rem;
      }
      @media (min-width: 640px) {
        .project-article pre code {
          font-size: 0.875rem;
        }
      }
      /* Safari-style browser mockup for GIFs */
      .project-article .browser-mockup {
        position: relative;
        border-radius: 0.75rem;
        overflow: hidden;
        margin: 1.5rem 0;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.05);
        background: #e5e5e5;
      }
      .dark .project-article .browser-mockup {
        background: #404040;
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1);
      }
      .project-article .browser-mockup::before {
        content: '';
        display: block;
        height: 2.5rem;
        background: #f5f5f5;
        border-bottom: 1px solid #e0e0e0;
        position: relative;
      }
      .dark .project-article .browser-mockup::before {
        background: #262626;
        border-bottom-color: #404040;
      }
      .project-article .browser-mockup::after {
        content: '● ● ●';
        position: absolute;
        top: 0.6rem;
        left: 0.875rem;
        font-size: 0.75rem;
        letter-spacing: 0.25rem;
        color: #d4d4d4;
      }
      .dark .project-article .browser-mockup::after {
        color: #525252;
      }
      .project-article .browser-mockup img {
        display: block;
        width: 100%;
        height: auto;
        margin: 0 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
      }
    </style>
  </body>
</html>
