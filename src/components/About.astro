---
const personalImageAlt = "Andres Villarreal"
import Photocard from "./photocards/photocard.astro"

const techs = [
  "Java","Spring Boot","Linux","Python",".NET Core","AWS",
  "Docker","Kubernetes","SQL","PostgreSQL","JavaScript","Angular","Astro"
]
---

<article class="grid gap-12 md:grid-cols-2 items-start text-gray-700 dark:text-gray-300">

  <!-- LEFT -->
  <div class="space-y-6">

    <!-- Tagline -->
    <p class="text-lg font-semibold text-yellow-500 dark:text-yellow-200">
      🔥 I build software, break it, fix it, and make it better..
    </p>

    <!-- Description -->
    <div class="space-y-4 text-pretty
                [&>p>strong]:font-mono
                [&>p>strong]:text-gray-900
                dark:[&>p>strong]:text-yellow-100">

      <p>
        Most of the time I’m working with <strong>.NET</strong>, building <strong>APIs and backend systems</strong> that are meant to <strong>handle real usage — not just demos.</strong>
      </p>

      <p>
        I also work <strong>hands-on as an electronic technician</strong>, which means I spend a lot of time dealing with <strong>Linux</strong>, hardware, and figuring out why something that <em>should work…</em> doesn’t.
      </p>

      <p>
        I’ve done <strong>full-stack work</strong>, played around with modern frameworks, SQL, and Python — but at the end of the day, I just like <strong>building things that work well and make sense.</strong>
      </p>

    </div>

    <!-- Tech Stack -->
    <div>
      <p class="mb-2 text-sm font-semibold text-gray-500 dark:text-gray-400">
        ⚙️ Tech Stack
      </p>

      <div class="flex flex-wrap gap-3 text-xs">
        {techs.map((tech) => (
          <span
            class="group relative px-3 py-1 rounded-md border 
                   
                   border-black/10 dark:border-white/10
                   bg-black/5 dark:bg-white/5
                   
                   transition-all duration-300 ease-out
                   hover:-translate-y-1 hover:scale-105
                   
                   hover:border-cyan-500/60 dark:hover:border-cyan-400/40
                   
                   hover:bg-gradient-to-r 
                   hover:from-cyan-500/20 hover:to-purple-500/20
                   dark:hover:from-cyan-500/10 dark:hover:to-purple-500/10
                   
                   cursor-default overflow-hidden"
          >

            <!-- glow -->
            <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-300
                        bg-gradient-to-r 
                        from-cyan-500/20 to-purple-500/20
                        dark:from-cyan-400/20 dark:to-purple-500/20
                        blur-md"></span>

            <!-- text -->
            <span class="relative z-10 tracking-wide 
                        text-gray-800 dark:text-gray-200
                        group-hover:text-black dark:group-hover:text-white">
              {tech}
            </span>
          </span>
        ))}
      </div>
    </div>

    <!-- Strengths -->
    <div class="grid grid-cols-2 gap-3 text-sm">
      <div>🚀 Backend & APIs</div>
      <div>☁️ Cloud & DevOps</div>
      <div>📊 Data Workflows</div>
      <div>🛠 Linux & Hardware</div>
    </div>

    <!-- Focus -->
    <p class="text-sm text-gray-500 dark:text-gray-400">
      🎯 Focused on backend scalability, cloud architecture, and performance.
    </p>

  </div>

  <!-- RIGHT (BENTO) -->
  <div class="grid grid-cols-2 gap-4">

    <!-- IMAGE -->
    <div class="col-span-2 group relative"> <!-- ✨ perspectiva añadida -->
    
      <Photocard 
      src="/me3.jpg"
      alt={personalImageAlt}
      badgeText="🚀 Open to Opportunities"
    />
    
</div>

    <!-- CARD 1 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">🎯 Focused</p>
      <p class="text-gray-600 dark:text-gray-400">Linux</p>
      <p class="text-gray-600 dark:text-gray-400">Refurbishment</p>
      <p class="text-gray-600 dark:text-gray-400">Java</p>
      
      
    </div>

    <!-- CARD 2 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">🌍 Location</p>
      <p class="text-gray-600 dark:text-gray-400">
        📍 Toronto, 🇨🇦
      </p>
    </div>

    <!-- CARD 3 -->
    <div class="col-span-2 rounded-2xl p-4 text-sm
                bg-gradient-to-r from-cyan-500/10 to-purple-500/10
                border border-cyan-500/20
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">Personal Interests</p>
      <p class="text-gray-700 dark:text-gray-300">🚴 Cycling around the city</p>
      <p class="text-gray-700 dark:text-gray-300">📚 Reading whenever I get the time</p>
      <p class="text-gray-700 dark:text-gray-300">🧙‍♂️ Medieval movies (LOTR fan)</p>
    </div>

  </div>

</article>

<script>
  import '../scripts/about'
</script>