---
const personalImageAlt = "Andres Villarreal"

const techs = [
  "Java","Spring Boot","Linux","Python",".NET Core","AWS",
  "Docker","Kubernetes","SQL","PostgreSQL","JavaScript","Angular","Astro"
]
---

<article class="grid gap-12 md:grid-cols-2 items-start text-gray-700 dark:text-gray-300">

  <!-- LEFT -->
  <div class="space-y-6">

    <!-- Tagline -->
    <p class="text-lg font-semibold text-yellow-500 dark:text-yellow-300">
      💻 I build scalable systems that solve real-world problems.
    </p>

    <!-- Description -->
    <div class="space-y-4 text-pretty
                [&>p>strong]:font-mono
                [&>p>strong]:text-gray-900
                dark:[&>p>strong]:text-white">

      <p>
        Software developer specializing in <strong>.NET</strong>, focused on building scalable APIs and reliable backend systems.
      </p>

      <p>
        Currently working as an Electronic Technician, combining software with 
        <strong>hands-on Linux deployments</strong> on rugged devices where performance and stability are critical.
      </p>

      <p>
        Experience across full-stack environments, working with modern frameworks, SQL, and building data workflows using <strong>Python</strong>.
      </p>

    </div>

    <!-- Tech Stack -->
    <div>
      <p class="mb-2 text-sm font-semibold text-gray-500 dark:text-gray-400">
        ⚙️ Tech Stack
      </p>

      <div class="flex flex-wrap gap-3 text-xs">
        {techs.map((tech) => (
          <span
            class="group relative px-3 py-1 rounded-md border 
                   
                   border-black/10 dark:border-white/10
                   bg-black/5 dark:bg-white/5
                   
                   transition-all duration-300 ease-out
                   hover:-translate-y-1 hover:scale-105
                   
                   hover:border-cyan-500/60 dark:hover:border-cyan-400/40
                   
                   hover:bg-gradient-to-r 
                   hover:from-cyan-500/20 hover:to-purple-500/20
                   dark:hover:from-cyan-500/10 dark:hover:to-purple-500/10
                   
                   cursor-default overflow-hidden"
          >

            <!-- glow -->
            <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-300
                        bg-gradient-to-r 
                        from-cyan-500/20 to-purple-500/20
                        dark:from-cyan-400/20 dark:to-purple-500/20
                        blur-md"></span>

            <!-- text -->
            <span class="relative z-10 tracking-wide 
                        text-gray-800 dark:text-gray-200
                        group-hover:text-black dark:group-hover:text-white">
              {tech}
            </span>
          </span>
        ))}
      </div>
    </div>

    <!-- Strengths -->
    <div class="grid grid-cols-2 gap-3 text-sm">
      <div>🚀 Backend & APIs</div>
      <div>☁️ Cloud & DevOps</div>
      <div>📊 Data Workflows</div>
      <div>🛠 Linux & Hardware</div>
    </div>

    <!-- Focus -->
    <p class="text-sm text-gray-500 dark:text-gray-400">
      🎯 Focused on backend scalability, cloud architecture, and performance.
    </p>

  </div>

  <!-- RIGHT (BENTO) -->
  <div class="grid grid-cols-2 gap-4">

    <!-- IMAGE -->
    <div class="col-span-2 group relative rounded-2xl overflow-hidden
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                p-2">

      <img 
        src="/me3.jpg" 
        alt={personalImageAlt}
        class="w-full h-full object-cover aspect-square rounded-xl
               transition duration-500
               group-hover:scale-105"
      />

      <!-- overlay -->
      <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition
                  bg-gradient-to-tr from-cyan-500/20 to-purple-500/20"></div>

      <!-- badge -->
      <div class="absolute bottom-3 left-3 text-xs px-3 py-1 rounded-full
                  bg-white/70 dark:bg-black/60
                  backdrop-blur-md border border-black/10 dark:border-white/10">
        🚀 Open to Opportunities
      </div>
    </div>

    <!-- CARD 1 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">⚡ Experience</p>
      <p class="text-gray-600 dark:text-gray-400">
        Backend systems, cloud, and device optimization
      </p>
    </div>

    <!-- CARD 2 -->
    <div class="rounded-2xl p-4 text-sm
                bg-black/5 dark:bg-white/5
                border border-black/10 dark:border-white/10
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">🌍 Location</p>
      <p class="text-gray-600 dark:text-gray-400">
        Canada
      </p>
    </div>

    <!-- CARD 3 -->
    <div class="col-span-2 rounded-2xl p-4 text-sm
                bg-gradient-to-r from-cyan-500/10 to-purple-500/10
                border border-cyan-500/20
                hover:scale-[1.02] transition">

      <p class="font-semibold mb-1">🎯 Current Focus</p>
      <p class="text-gray-700 dark:text-gray-300">
        Scalable backend systems and cloud architecture
      </p>
    </div>

  </div>

</article>