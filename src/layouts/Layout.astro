---
import '@fontsource-variable/onest';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { ViewTransitions } from "astro:transitions"

interface Props {
	title: string; 
	description: string;
	currentLocale?: string;
}

const { description, title, currentLocale: localeProp } = Astro.props;
const currentLocale = localeProp ?? Astro.currentLocale ?? 'en';
---

<!doctype html>
<html lang={currentLocale}> 
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/main_icons/iconb.png" />
		<link rel="apple-touch-icon" href="/main_icons/icona.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#030712" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={`https://andresvillarreal.netlify.app${Astro.url.pathname}`} />

    <!-- Open Graph / LinkedIn / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://andresvillarreal.netlify.app${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://andresvillarreal.netlify.app/me3.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Andrés Villarreal — Full-Stack Developer" />
    <meta property="og:locale" content={currentLocale === 'es' ? 'es_CO' : currentLocale === 'fr' ? 'fr_CA' : 'en_CA'} />
    <meta property="og:site_name" content="Andrés Villarreal — Portfolio" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`https://andresvillarreal.netlify.app${Astro.url.pathname}`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://andresvillarreal.netlify.app/me3.jpg" />
    <meta name="twitter:image:alt" content="Andrés Villarreal — Full-Stack Developer" />

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href="/me3.jpg" fetchpriority="high" />
    <ViewTransitions />

    <!-- Auto-detect language on first visit and redirect — deferred to avoid blocking LCP -->
    <script is:inline>
      (function () {
        if (typeof localStorage === 'undefined') return;
        if (localStorage.getItem('lang-redirected')) return;

        const path = window.location.pathname;
        if (path.startsWith('/es') || path.startsWith('/fr')) return;

        const lang = (navigator.language || 'en').toLowerCase().slice(0, 2);
        localStorage.setItem('lang-redirected', '1');

        // Defer redirect so it doesn't block first paint / LCP
        if (lang === 'es' || lang === 'fr') {
          requestAnimationFrame(function () {
            window.location.replace('/' + lang + '/');
          });
        }
      })();
    </script>

    <!-- Apply dark/light theme before paint to avoid flash -->
    <script is:inline>
      (function applyStoredTheme() {
        const stored = typeof localStorage !== 'undefined'
          ? localStorage.getItem('theme')
          : null;
        const preference = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = preference === 'dark' || (preference === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      })();

      // Re-apply after every ViewTransitions navigation so the class is never lost
      document.addEventListener('astro:after-swap', function () {
        const stored = typeof localStorage !== 'undefined'
          ? localStorage.getItem('theme')
          : null;
        const preference = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = preference === 'dark' || (preference === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      });
    </script>
	</head>
	<body class="text-black dark:text-white">
		<div
		class="fixed top-0 bottom-0 left-0 right-0 z-[-2] w-full bg-gray-50 dark:bg-gray-950
		bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(217,216,255,0.5),rgba(255,255,255,0.9))]
		dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"
	  >
	  </div>
		<Header currentLocale={currentLocale} />
		<slot />
		<Footer currentLocale={currentLocale} />
  <style is:global>
    :root {
      
      color-scheme: light dark;
    }
    html {
      font-family:"Onest Variable", system-ui, sans-serif;
      scroll-behavior: smooth;
      
    }
    body{
     color: rgba(17, 17, 17, 0.9);
          display:flex;
          flex-direction: column;
          min-height: 100vh;
          overscroll-behavior: none;
  
    }
  
    @media (prefers-reduced-motion: reduce) {
          html {
            scroll-behavior: auto;
          }
        }
  
        /* Use .dark class (controlled by ThemeToggle) instead of media query */
        .dark body {
          color: rgba(255, 255, 255, 0.9);
        }
  
        #header-menu{
          border-radius: 25px;
        }
        #header-nav {
          animation: blur linear both 0.5s;
          animation-timeline: scroll();
          border: none;
          
        }
  
        @keyframes blur {
          to {
            backdrop-filter: blur(20px);
            border-width: 1px;
            border-color: rgba(0, 0, 0);
            padding: 0.25rem 0.75rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            background-color: rgb(229, 229, 229);
            border-radius: 9999px;
          }
        }
  
        /* Dark mode nav blur — driven by .dark class, not media query */
        html.dark #header-nav {
          animation: blur-dark linear both 0.5s;
          animation-timeline: scroll();
        }

        @keyframes blur-dark {
            from {
              border: 0px;
            }
            to {
              box-shadow:
                0px 5px 50px -5px rgba(0, 0, 0, 0.1),
                0px 0px 0 1px rgba(0, 0, 0, 0.3);
              background: rgba(0, 0, 0, 0.3);
              backdrop-filter: blur(20px);
              border-width: 1px;
              border-color: rgba(0, 0, 0);
              padding-left: 0.75rem;
              padding-right: 0.75rem;
              padding-top: 0.25rem;
              padding-bottom: 0.25rem;
              display: flex;
              flex-direction: row;
              align-items: center;
              background-color: rgba(0, 0, 0, 0.3);
              border-radius: 9999px;
            }
        }
    
  </style>

	</body>
  
</html>

