---
import '@fontsource-variable/onest';
import ProjectHeader from '@/components/ProjectHeader.astro';
import Footer from '@/components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
  title: string;
  description: string;
  image: string;
  subtitle: string;
  stack: string[];
  liveUrl?: string | null;
  codeUrl?: string | null;
}

const {
  currentLocale = 'en',
  title,
  description,
  image,
  subtitle,
  stack,
  liveUrl,
  codeUrl,
} = Astro.props;

const i18n = getI18N({ currentLocale });
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/main_icons/iconb.png" />
    <link rel="apple-touch-icon" href="/main_icons/icona.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#030712" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Andrés Villarreal</title>
    <link rel="canonical" href={`https://andresvillarreal.netlify.app${Astro.url.pathname}`} />
    <ViewTransitions />

    <!-- Apply dark/light theme before paint -->
    <script is:inline>
      (function () {
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        const pref = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = pref === 'dark' || (pref === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      })();
      document.addEventListener('astro:after-swap', function () {
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        const pref = stored ?? 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = pref === 'dark' || (pref === 'system' && prefersDark);
        document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      });
    </script>
  </head>

  <body class="text-black dark:text-white">
    <!-- Same background gradient as main layout -->
    <div class="fixed top-0 bottom-0 left-0 right-0 z-[-2] w-full bg-gray-50 dark:bg-gray-950
                bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(217,216,255,0.5),rgba(255,255,255,0.9))]
                dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]">
    </div>

    <ProjectHeader currentLocale={currentLocale} />

    <main class="px-4 sm:px-6 max-w-3xl mx-auto pt-24 sm:pt-28 pb-12 sm:pb-20">

      <!-- Hero image -->
      <div class="w-full aspect-[3/2] rounded-2xl overflow-hidden
                  bg-gray-100 dark:bg-neutral-800
                  ring-1 ring-black/5 dark:ring-white/10 mb-8">
        <img src={image} alt={title} class="w-full h-full object-cover" />
      </div>

      <!-- Subtitle + title -->
      <p class="text-xs sm:text-sm font-semibold uppercase tracking-widest
                text-gray-400 dark:text-gray-500 mb-2">
        {subtitle}
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold
                 text-neutral-900 dark:text-white leading-tight mb-4">
        {title}
      </h1>

      <!-- Tech stack pills -->
      <div class="flex flex-wrap gap-2 mb-8">
        {stack.map(tech => (
          <span class="inline-block rounded-full bg-gray-100 dark:bg-neutral-800
                       px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300">
            {tech}
          </span>
        ))}
      </div>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-3 mb-10">
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-full bg-neutral-900 dark:bg-white
                    px-5 py-2.5 text-sm font-semibold
                    text-white dark:text-neutral-900
                    hover:bg-neutral-700 dark:hover:bg-gray-100
                    transition-colors duration-200">
            {i18n.CAROUSEL.liveDemo}
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
        {codeUrl && (
          <a href={codeUrl} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-full
                    border border-gray-300 dark:border-gray-600
                    px-5 py-2.5 text-sm font-semibold
                    text-neutral-700 dark:text-gray-200
                    hover:bg-gray-100 dark:hover:bg-neutral-800
                    transition-colors duration-200">
            {i18n.CAROUSEL.sourceCode}
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </a>
        )}
      </div>

      <!-- Divider -->
      <hr class="border-gray-200 dark:border-neutral-800 mb-10" />

      <!-- Content -->
      <div class="prose prose-neutral dark:prose-invert max-w-none
                  prose-headings:font-semibold prose-p:leading-relaxed
                  prose-p:text-gray-700 dark:prose-p:text-gray-300">
        <slot />
      </div>

    </main>

    <Footer currentLocale={currentLocale} />

    <style is:global>
      :root { color-scheme: light dark; }
      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }
      body {
        color: rgba(17, 17, 17, 0.9);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
      }
      .dark body { color: rgba(255, 255, 255, 0.9); }
    </style>
  </body>
</html>
