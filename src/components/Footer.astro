---
import { getI18N, getLocalePath } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const base = getLocalePath(currentLocale);
const currentYear = new Date().getFullYear();
---

<footer class="opacity-90 m-4 mt-16 w-full mx-auto container lg:max-w-4xl md:max-w-2xl mb-10 flex justify-center px-5">
  <div class="rounded-lg w-full max-w-screen-xl mx-auto md:flex md:items-center md:justify-between py-4">
    <span class="text-sm sm:text-center text-gray-600 dark:text-gray-400">
      © <span id="footer-year">{currentYear}</span>
      <a href={`${base}/#home`} class="font-medium text-gray-800 dark:text-gray-200 hover:text-yellow-600 dark:hover:text-yellow-400 hover:underline transition">Andres Villarreal</a>.
    </span>
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-2 mt-3 text-sm font-medium sm:mt-0">
      <li><a href={`${base}/#education`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline transition">{i18n.FOOTER.education}</a></li>
      <li><a href={`${base}/#experience`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline transition">{i18n.FOOTER.experience}</a></li>
      <li><a href={`${base}/#projects`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline transition">{i18n.FOOTER.projects}</a></li>
      <li><a href={`${base}/#about`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline transition">{i18n.FOOTER.about}</a></li>
      <li><a href={`${base}/#contact`} class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline transition">{i18n.FOOTER.contact}</a></li>
    </ul>
  </div>
  <!-- Dynamic year update (handles cached pages) -->
  <script is:inline>
    document.getElementById('footer-year').textContent = new Date().getFullYear();
  </script>
</footer>
