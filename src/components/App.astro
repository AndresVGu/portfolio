---
import Layout from '../layouts/Layout.astro';
import Briefcase from '../Icons/Briefcase.astro';
import EduIcon from '../Icons/PapersIcon.astro';
import CodeIcon from '../Icons/Code.astro';
import ProfileIcon from '../Icons/ProfileIcon.astro';
import Experience from '../components/TimeLine.astro';
import Education from '../components/Education.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Profile from '../components/Profile.astro';
import About from '../components/About.astro';
import Certificates from '@/components/Certificates.astro';
import Test from '@/components/Test.astro';
import AppleCarousel from '@/components/AppleCarousel.astro';
import ContactForm from '@/components/ContactForm.astro';
import SendModal from '@/components/SendModal.astro';
import PhotoCardModal from '@/components/PhotoCardModal.astro';
import MemoryGame from '@/components/MemoryGame.astro';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale: localeProp } = Astro.props;
const { currentLocale: astroLocale = 'en' } = Astro;
const currentLocale = localeProp ?? astroLocale;
const i18n = getI18N({ currentLocale });
---

<Layout
  title={i18n.SEO_TITLE}
  description={i18n.SEO_DESCRIPTION}
>
  <main class="px-4 sm:px-6">

    <SectionContainer class="py-16 md:py-36 animate-fade-right animate-duration-1500" id="home">
      <Profile currentLocale={currentLocale} />
    </SectionContainer>

    <div class="space-y-16 sm:space-y-24">

      <SectionContainer id="experience">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <Briefcase class="size-6 sm:size-7" />
          {i18n.TITLES.experience}
        </h2>
        <Experience currentLocale={currentLocale} />
      </SectionContainer>

      {/* Bento projects — hidden, kept for reference */}
      {/* <SectionContainer id="projects">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <CodeIcon class="size-6 sm:size-7" />
          {i18n.TITLES.projects}
        </h2>
        <Test currentLocale={currentLocale} />
      </SectionContainer> */}

      <SectionContainer id="projects" class="!max-w-none !px-0 overflow-visible">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300
                   max-w-2xl md:max-w-3xl lg:max-w-4xl xl:max-w-5xl mx-auto px-4 sm:px-6">
          <CodeIcon class="size-6 sm:size-7" />
          {i18n.TITLES.projects}
        </h2>
        <AppleCarousel currentLocale={currentLocale} />
      </SectionContainer>

      <SectionContainer id="education">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <EduIcon class="size-6 sm:size-7" />
          {i18n.TITLES.education}
        </h2>
        <Education currentLocale={currentLocale} />
        <br />
        <h3 class="flex items-center mb-6 text-xl sm:text-2xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          {i18n.TITLES.certificates}
        </h3>
        <Certificates />
      </SectionContainer>

      <SectionContainer id="about">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <ProfileIcon class="size-6 sm:size-7" />
          {i18n.TITLES.about}
        </h2>
        <About currentLocale={currentLocale} />
      </SectionContainer>

      <SectionContainer id="game">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <!-- Game / puzzle icon -->
          <svg class="size-6 sm:size-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
          </svg>
          Tech Memory
        </h2>
        <MemoryGame currentLocale={currentLocale} />
      </SectionContainer>

      <SectionContainer id="contact">
        <h2 class="flex items-center mb-6 text-2xl sm:text-3xl font-semibold gap-x-3 text-black/80 dark:text-yellow-300">
          <!-- Mail icon inline SVG -->
          <svg class="size-6 sm:size-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {i18n.CONTACT.title}
        </h2>
        <ContactForm currentLocale={currentLocale} />
      </SectionContainer>

    </div>

  </main>
</Layout>

<!-- Modals live outside main so they can overlay everything -->
<SendModal />
<PhotoCardModal />
