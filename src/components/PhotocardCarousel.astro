---
/**
 * PhotocardCarousel.astro
 * Animated photo deck carousel with text panel — replaces old grid gallery.
 *
 * CSS  → src/styles/photocard-carousel.css
 * JS   → initialized externally via About.astro script tag
 */
import { getI18N } from '@/i18n';
import '../styles/photocard-carousel.css';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const photocards = i18n.ABOUT.photocards;
const nav = i18n.ABOUT.photocardNav;
---

<div class="photocard-carousel" data-photocard-carousel data-autoplay="5000">
  <div class="photocard-carousel__layout">

    <!-- Left: Photo Deck -->
    <div class="photocard-carousel__deck">
      <div class="photocard-carousel__deck-container">
        {photocards.map((card, i) => (
          <img
            class={`photocard-carousel__card ${i === 0 ? 'photocard-carousel__card--active' : 'photocard-carousel__card--inactive'}`}
            data-card-index={String(i)}
            data-label={card.label}
            data-description={card.description}
            src={card.src}
            alt={card.label}
            loading="lazy"
          />
        ))}
      </div>
      <!-- Navigation arrows below deck -->
      <div class="photocard-carousel__nav">
        <button data-photocard-prev aria-label={nav.prev}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button data-photocard-next aria-label={nav.next}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Right: Text Panel -->
    <div class="photocard-carousel__text">
      <h3 class="photocard-carousel__label" data-photocard-label>{photocards[0]?.label}</h3>
      <p class="photocard-carousel__description" data-photocard-description>{photocards[0]?.description}</p>
    </div>

  </div>
</div>
