---
import Link from "../Icons/Link.astro";
import GitHub from "../Icons/Github.astro";
import Microsoft from "../Icons/Microsoft.astro";
import LinkButton from '../components/LinkButton.astro';
import Azure from '../Icons/Azure.astro';
import SqlIcon from '../Icons/SqlIcon.astro';
import Html5 from '../Icons/HtmlIcon.astro';
import Css3 from '../Icons/CssIcon.astro';
import JavascriptIcon from '../Icons/JavascriptIcon.astro';
import React from '../Icons/ReactIcon.astro';
import AstroIcon from '../Icons/AstroIcon.astro';
import TypeScript from'../Icons/TypeScriptIcon.astro';
import Svelte from '../Icons/SvelteIcon.astro';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
  class?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const p = i18n.PROJECTS;
---

<section
    class={`
        w-full max-w-[1400px]
        grid grid-cols-5 auto-rows-[18rem] sm:auto-rows-[24rem] md:auto-rows-[30rem]
        gap-4 md:gap-6
        mx-auto
    `}>

    <!--ITEM #1 -->
    <article class={`
        ${Astro.props.class}
        col-span-5
        md:col-span-3
        relative rounded-xl
        backdrop-blur-md
        border border-black/10
        shadow-inner shadow-white/10
        group
        `}
        data-modal-target="first-modal" data-modal-toggle="first-modal"
        >
            <div class="absolute z-10 bottom-0 top-0 w-full h-full 
            bg-gradient-to-b from-transparent from-50% via-black-black/20 to-black/70 duration-700 ease-in-out group-hover:scale-105">
            <div
              class="background transition-scale absolute bottom-0 left-0 top-0
                -z-10 h-full w-full 
                bg-cover bg-center bg-no-repeat opacity-90 bg-blend-luminosity duration-700 ease-in-out group-hover:scale-105 "
              style="background-image: url('/projects/bg.webp');">        
            </div>    
            </div>
                   
            <slot name="image"></slot>
        
            <div class="relative select-none flex flex-col gap-1 p-4 sm:p-6 text-lg z-20 justify-end h-full">
            <h2 class="text-xl sm:text-2xl md:text-3xl font-semibold text-balance text-white mb-2 sm:mb-4">{p[0].title}</h2>
            <h3 class="text-lg sm:text-xl md:text-3xl font-semibold text-sky-200/80 -mt-2 sm:-mt-4 mb-2 sm:mb-4">{p[0].subtitle}</h3>
        </div>
    </article>

     <!-- Main modal -->
  <div id="first-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full  md:inset-0 h-full bg-black bg-opacity-50">
    
    <div class=" p-4 w-full max-w-2xl max-h-full fixed  ">

        <!-- Modal content -->
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <!-- Modal header -->
            <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                    {p[0].title}
                </h3>
                <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="first-modal">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                    <span class="sr-only">Close modal</span>
                </button>
            </div>
            <!-- Modal body -->
             
            <div class="p-4 md:p-5 space-y-4">
                <section
                class={`grid grid-cols-4 gap-2`}>

                <div class="col-span-2  md:col-span-1">
                    <div class={`flex font-medium rounded-lg text-sm px-5 py-2.5 text-center me-2 mb-2 dark:text-white gap-2 transition-all duration-300 hover:scale-110`}>
                        <Microsoft class="size-5"/>
                        <span>ASP.NET</span>
                    </div>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <div class={`flex font-medium rounded-lg text-sm px-5 py-2.5 text-center me-2 mb-2 dark:text-white gap-2 transition-all duration-300 hover:scale-110`}>
                        <Azure class="size-5"/>
                        <span>Azure</span>    
                    </div>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <div class={`flex font-medium rounded-lg text-sm px-5 py-2.5 text-center me-2 mb-2 dark:text-white gap-2 transition-all duration-300 hover:scale-110`}>
                        <SqlIcon class="size-5"/>
                        <span>SQLite</span>    
                    </div>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <div class={`flex font-medium rounded-lg text-sm px-5 py-2.5 text-center me-2 mb-2 dark:text-white gap-2 transition-all duration-300 hover:scale-110`}>
                        <JavascriptIcon class="size-5"/>
                        <span>JavaScript</span>

                    </div>
                </div>

                </section>
               
                <p class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-500
                    [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300">
                    {p[0].description}
                </p>

                <div class="pswp-gallery pswp-gallery--single-column" id="gallery-nbd">
 
    <a href="/projects/NBD/image-1.webp" target="_blank" role="link" 
