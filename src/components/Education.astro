---
import EducationItem from '../components/EducationTimeLine.astro';
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
---

<ol class="relative mt-16">
  {i18n.EDUCATION.map((edu) => (
    <li>
      <EducationItem
        startDate={''}
        endDate={edu.endDate}
        title={edu.title}
        company={edu.company}
        description={edu.description}
      />
    </li>
  ))}
</ol>
