---
import LinkInLine from '../components/LinkInLine.astro';

interface Props {
  startDate: string;
  endDate: string;
  title: string;
  company: string;
  description: string;
  link?: string;
  credential?: string;
}

const { startDate, endDate, title, company, description, link, credential } = Astro.props;
---

<div class="relative pl-8 sm:pl-0 mx-4 sm:mx-8 md:mx-12 pb-10 grid
            md:grid-cols-5 md:gap-10
            before:absolute before:left-3 md:before:left-[-35px]
            before:block before:h-full
            before:border-l-2 before:border-black/20 dark:before:border-white/15
            before:content-['']">

  <div class="relative pb-6 md:pb-12 md:col-span-2">
    <div class="sticky top-0">
      <span class="text-yellow-400 absolute left-[-26px] md:left-[-42px] rounded-full text-4xl md:text-5xl">&bull;</span>
      <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-sky-200">{title}</h3>
      <h4 class="font-semibold text-base sm:text-lg text-gray-600 dark:text-gray-300">{company}</h4>
      {credential && (
        <p class="text-xs sm:text-sm font-medium text-yellow-600 dark:text-yellow-400">{credential}</p>
      )}
      <time class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 block">{startDate}</time>
      <time class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 block">{endDate}</time>
    </div>
  </div>

  <div class="flex flex-col gap-2 pb-4 text-sm sm:text-base text-gray-600 dark:text-gray-300 md:col-span-3">
    {description}
    {link && (
      <LinkInLine href={link}>
        Verify{" "}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 sm:w-5" width="24" height="24"
             viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
             stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M9 6l6 6l-6 6" />
        </svg>
      </LinkInLine>
    )}
  </div>
</div>
