---
import LinkInLine from '../components/LinkInLine.astro';

const { startDate, endDate, title, company, description, list, link } = Astro.props;
---

<div class="timeline-item step relative mx-6 md:mx-12 pb-20 grid md:grid-cols-5 md:gap-10">

  <!-- PROGRESS LINE -->
  <div class="timeline-line absolute left-0 md:left-[-20px] top-0 w-[3px] h-full bg-black/10 dark:bg-white/10 overflow-hidden">
    <div class="progress bg-gradient-to-b from-yellow-400 via-cyan-400 to-transparent w-full h-0 transition-all duration-500"></div>
  </div>

  <!-- DOT -->
  <span class="dot absolute left-[-8px] md:left-[-28px] top-2 w-5 h-5 rounded-full bg-black/30 dark:bg-white/30 transition-all duration-300"></span>

  <!-- LEFT -->
  <div class="md:col-span-2 ml-6">
    <div class="content-left opacity-0 translate-y-10 transition-all duration-500">
      <h3 class="text-2xl font-bold text-black dark:text-white">{title}</h3>
      <h4 class="text-lg text-gray-700 dark:text-gray-300">{company}</h4>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        {startDate} — {endDate}
      </p>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="md:col-span-3 ml-4 mt-4 md:mt-0 ">
    <div class="card content-right opacity-0 translate-y-10 relative p-6 rounded-2xl bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl overflow-hidden transition-all duration-500">

      <!-- GLOW -->
      <div class="glow pointer-events-none absolute inset-0 opacity-0 transition duration-300"></div>

      <p class="text-gray-800 dark:text-gray-200">{description}</p>

      <div class="mt-3 text-sm text-gray-600 dark:text-gray-400">{list}</div>

      {
        link && (
          <div class="mt-4">
            <LinkInLine href={link}>
              See more →
            </LinkInLine>
          </div>
        )
      }

    </div>
  </div>
</div>

<script>
  import '../scripts/timeLineItem'
</script>

<style>
  /* DOT POP ANIMATION 🔥 */
  .dot-pop {
    animation: pop 0.35s ease;
  }

  @keyframes pop {
    0% {
      transform: scale(0.6);
    }
    50% {
      transform: scale(1.4);
    }
    100% {
      transform: scale(1);
    }
  }
</style>