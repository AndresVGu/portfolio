---
const { company, roles, labels, isFirst = false } = Astro.props;

const firstDate = roles[roles.length - 1]?.startDate ?? '';
const lastDate  = roles[0]?.endDate ?? '';
const location  = roles[0]?.location ?? '';

const labelStack      = labels?.stack ?? 'Tech Stack';
const labelHighlights = labels?.highlights ?? 'Highlights';
const labelViewDetails = labels?.viewDetails ?? 'View details';
const labelCurrent    = labels?.current ?? 'Current';
const labelPromoted   = labels?.promoted ?? 'Promoted';
const labelPermanent  = labels?.permanent ?? 'Permanent · Full-time';
---

<div class="timeline-item step relative pb-12 md:pb-20">

  <!-- DOT -->
  <span class={`dot absolute left-[5px] md:left-[-5px] top-2
               w-4 h-4 rounded-full transition-all duration-300 z-10
               ${isFirst ? 'bg-yellow-400 shadow-lg shadow-yellow-400/60' : 'bg-black/30 dark:bg-white/30'}`}></span>

  <!-- Content -->
  <div class="pl-10 md:pl-0 md:ml-8 grid md:grid-cols-5 md:gap-10">

    <!-- LEFT: company header -->
    <div class="md:col-span-2 mb-3 md:mb-0">
      <div class={`content-left transition-all duration-500 ${isFirst ? '' : 'opacity-0 translate-y-10'}`}>

        <div class="flex items-center gap-2 flex-wrap">
          <h3 class="text-xl md:text-2xl font-bold text-black dark:text-white">{company}</h3>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold
                       bg-yellow-400/20 text-yellow-600 dark:text-yellow-400
                       border border-yellow-400/30">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {labels?.promoted ?? 'Promoted'}
          </span>
        </div>

        <p class="text-xs md:text-sm text-gray-500 dark:text-gray-400 mt-1">
          {firstDate} — {lastDate}
        </p>

        {location && (
          <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-1 flex items-center gap-1">
            <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {location}
          </p>
        )}

        <span class="mt-2 inline-block text-[11px] font-medium text-gray-500 dark:text-gray-400">
          {labels?.permanent ?? 'Permanent · Full-time'}
        </span>

      </div>
    </div>

    <!-- RIGHT: stacked role cards -->
    <div class="md:col-span-3 flex flex-col gap-4">

      {roles.map((role: any, i: number) => {
        const isLatest = i === 0;
        const singleModalData = JSON.stringify({
          title:       role.title,
          company,
          location:    role.location ?? location,
          dates:       `${role.startDate} — ${role.endDate}`,
          description: role.modalDescription ?? role.description,
          stack:       role.stack      ?? [],
          highlights:  role.highlights ?? [],
          labelStack,
          labelHighlights,
        });

        return (
          <div class={`card content-right relative p-4 md:p-5
                       rounded-2xl overflow-hidden transition-all duration-500
                       bg-yellow-400/8 border border-yellow-400/25 dark:border-yellow-400/20
                       ${isFirst ? '' : 'opacity-0 translate-y-10'}`}>

            <div class="glow pointer-events-none absolute inset-0 opacity-0 transition duration-300"></div>

            <!-- Role header -->
            <div class="flex items-start justify-between gap-2 mb-2">
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <h4 class="text-base md:text-lg font-bold text-black dark:text-white">{role.title}</h4>
                  {isLatest && (
                    <span class="px-2 py-0.5 rounded-full text-[10px] font-bold
                                 bg-green-400/20 text-green-600 dark:text-green-400
                                 border border-green-400/30">
                      {labels?.current ?? 'Current'}
                    </span>
                  )}
                </div>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                  {role.startDate} — {role.endDate}
                </p>
              </div>
            </div>

            <p class="text-sm text-gray-800 dark:text-gray-200">{role.description}</p>
            <div class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 font-medium">{role.list}</div>

            <button
              class="exp-detail-btn mt-3 inline-flex items-center gap-1.5
                     text-xs font-semibold px-3 py-1.5 rounded-full
                     bg-black/8 dark:bg-white/10
                     hover:bg-black/15 dark:hover:bg-white/20
                     text-gray-700 dark:text-gray-200
                     border border-black/10 dark:border-white/10
                     transition-all duration-200 hover:gap-2.5 cursor-pointer"
              data-exp={singleModalData}
              aria-label={`${labels?.viewDetails ?? 'View details'} - ${role.title} @ ${company}`}
            >
              {labels?.viewDetails ?? 'View details'}
              <svg width="12" height="12" fill="none" viewBox="0 0 24 24"
                   stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </button>

          </div>
        );
      })}

    </div>
  </div>
</div>

<style>
  .dot-pop {
    animation: pop 0.35s ease;
  }
  @keyframes pop {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }
</style>
