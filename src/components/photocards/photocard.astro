---
const { src, alt, badgeText } = Astro.props;
---

<div class="card-scene relative rounded-2xl overflow-hidden
            bg-black/5 dark:bg-white/5
            border border-black/10 dark:border-white/10
            p-2 group cursor-pointer select-none">

  <!-- Imagen principal -->
  <img
    src={src}
    alt={alt}
    class="card-img w-full h-full object-cover aspect-square rounded-xl
           will-change-transform"
  />

  <!-- Rainbow holo base -->
  <div class="card-holo absolute inset-0 rounded-xl pointer-events-none opacity-0"></div>

  <!-- Diagonal shine beam (the main streak) -->
  <div class="card-shine absolute inset-0 rounded-xl pointer-events-none opacity-0"></div>

  <!-- badge -->
  {badgeText && (
    <div class="absolute bottom-3 left-3 text-xs px-3 py-1 rounded-full
                bg-white/70 dark:bg-black/60
                backdrop-blur-md border border-black/10 dark:border-white/10
                z-10">
      {badgeText}
    </div>
  )}
</div>

<style>
  .card-scene {
    perspective: 900px;
    transform-style: preserve-3d;
  }
  .card-img {
    transform-style: preserve-3d;
    transition: transform 0.08s linear;
  }

  /* Subtle rainbow base — always covers the card, shifts with cursor */
  .card-holo {
    mix-blend-mode: color-dodge;
    transition: opacity 0.3s ease;
  }

  /* The diagonal light beam — sharp streak like a foil card */
  .card-shine {
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
  }
</style>

<script>
  import '../../scripts/about'
</script>
