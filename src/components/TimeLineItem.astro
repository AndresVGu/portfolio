---
const {
  startDate, endDate, title, company, location,
  description, list,
  modalDescription, stack, highlights, labels
} = Astro.props;

const modalData = JSON.stringify({
  title,
  company,
  location,
  dates: `${startDate} — ${endDate}`,
  description: modalDescription ?? description,
  stack:       stack      ?? [],
  highlights:  highlights ?? [],
  labelStack:      labels?.stack ?? 'Tech Stack',
  labelHighlights: labels?.highlights ?? 'Highlights',
});
---

<div class="timeline-item step relative pb-12 md:pb-20">

  <!-- DOT -->
  <span class="dot absolute left-[5px] md:left-[-5px] top-2
               w-4 h-4 rounded-full
               bg-black/30 dark:bg-white/30
               transition-all duration-300 z-10"></span>

  <!-- Content -->
  <div class="pl-10 md:pl-0 md:ml-8 grid md:grid-cols-5 md:gap-10">

    <!-- LEFT: company + dates (title goes in the card, matching group style) -->
    <div class="md:col-span-2 mb-3 md:mb-0">
      <div class="content-left opacity-0 translate-y-10 transition-all duration-500">
        <h3 class="text-xl md:text-2xl font-bold text-black dark:text-white">{company}</h3>
        <p class="text-xs md:text-sm text-gray-500 dark:text-gray-400 mt-1">
          {startDate} — {endDate}
        </p>
        {location && (
          <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-1 flex items-center gap-1">
            <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {location}
          </p>
        )}
        <span class="mt-2 inline-block text-[11px] font-medium text-gray-500 dark:text-gray-400">
          {labels?.permanent ?? 'Permanent · Full-time'}
        </span>
      </div>
    </div>

    <!-- RIGHT: description card — identical style to TimeLineGroup cards -->
    <div class="md:col-span-3">
      <div class="card content-right opacity-0 translate-y-10 relative p-4 md:p-5
                  rounded-2xl backdrop-blur-xl overflow-hidden transition-all duration-500
                  bg-yellow-400/8 border border-yellow-400/25 dark:border-yellow-400/20">

        <div class="glow pointer-events-none absolute inset-0 opacity-0 transition duration-300"></div>

        <!-- Role title inside the card -->
        <div class="flex items-center gap-2 flex-wrap mb-1">
          <h4 class="text-base md:text-lg font-bold text-black dark:text-white">{title}</h4>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{startDate} — {endDate}</p>

        <p class="text-sm text-gray-800 dark:text-gray-200">{description}</p>
        <div class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 font-medium">{list}</div>

        <button
          class="exp-detail-btn mt-3 inline-flex items-center gap-1.5
                 text-xs font-semibold px-3 py-1.5 rounded-full
                 bg-black/8 dark:bg-white/10
                 hover:bg-black/15 dark:hover:bg-white/20
                 text-gray-700 dark:text-gray-200
                 border border-black/10 dark:border-white/10
                 transition-all duration-200 hover:gap-2.5 cursor-pointer"
          data-exp={modalData}
          aria-label={`${labels?.viewDetails ?? 'View details'} - ${title} @ ${company}`}
        >
          {labels?.viewDetails ?? 'View details'}
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

      </div>
    </div>

  </div>
</div>

<script>
  import '../scripts/timeLineItem'
</script>

<style>
  .dot-pop {
    animation: pop 0.35s ease;
  }
  @keyframes pop {
    0%   { transform: scale(0.6); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }
</style>
