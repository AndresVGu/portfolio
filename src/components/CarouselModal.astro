---
import { getI18N } from '@/i18n';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
---

<div
  data-carousel-modal
  class="fixed inset-0 z-50 hidden h-screen overflow-auto"
>
  <!-- Backdrop -->
  <div
    data-carousel-backdrop
    class="fixed inset-0 size-full bg-black/80 backdrop-blur-lg
           opacity-0 transition-opacity duration-300"
  />

  <!-- Modal content -->
  <div
    data-carousel-modal-content
    class="relative z-[60] mx-4 sm:mx-auto my-6 sm:my-10 h-fit max-w-2xl rounded-3xl
           bg-white dark:bg-neutral-900 font-sans
           shadow-2xl dark:shadow-none
           opacity-0 translate-y-4 transition-all duration-300 overflow-hidden"
  >
    <!-- Hero image -->
    <div class="relative w-full aspect-[16/9] bg-gray-100 dark:bg-neutral-800 overflow-hidden">
      <img
        data-carousel-modal-image
        src=""
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Close button -->
      <button
        data-carousel-modal-close
        class="absolute top-3 right-3 z-10 flex size-8 items-center justify-center
               rounded-full bg-black/50 backdrop-blur-sm text-white
               hover:bg-black/70 transition-all duration-150"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Text content -->
    <div class="p-5 sm:p-7">
      <p
        data-carousel-modal-category
        class="text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"
      ></p>
      <h2
        data-carousel-modal-title
        class="mt-1 text-xl sm:text-2xl md:text-3xl font-semibold text-neutral-800 dark:text-white"
      ></h2>
      <p
        data-carousel-modal-description
        class="mt-3 text-sm sm:text-base text-gray-600 dark:text-gray-300 leading-relaxed"
      ></p>

      <!-- Tech stack icons -->
      <div class="mt-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">
          {i18n.CAROUSEL.techStack}
        </p>
        <div data-carousel-modal-stack class="flex flex-wrap gap-3"></div>
      </div>

      <!-- Action buttons -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <!-- View full project (always visible) -->
        <a
          data-carousel-modal-view-btn
          href="#"
          class="inline-flex items-center gap-2 rounded-full bg-neutral-900 dark:bg-white
                 px-5 py-2.5 text-sm font-semibold text-white dark:text-neutral-900
                 hover:bg-neutral-700 dark:hover:bg-gray-100 transition-colors duration-200"
        >
          {i18n.CAROUSEL.viewProject}
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Live demo (shown only when liveUrl exists) -->
        <a
          data-carousel-modal-live-btn
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="modal-optional-btn hidden items-center gap-2 rounded-full
                 border border-gray-300 dark:border-gray-600
                 px-5 py-2.5 text-sm font-semibold
                 text-neutral-700 dark:text-gray-200
                 hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors duration-200"
        >
          {i18n.CAROUSEL.liveDemo}
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>

        <!-- Source code (shown only when codeUrl exists) -->
        <a
          data-carousel-modal-code-btn
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="modal-optional-btn hidden items-center gap-2 rounded-full
                 border border-gray-300 dark:border-gray-600
                 px-5 py-2.5 text-sm font-semibold
                 text-neutral-700 dark:text-gray-200
                 hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors duration-200"
        >
          {i18n.CAROUSEL.sourceCode}
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>
