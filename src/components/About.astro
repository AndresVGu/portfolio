---
/**
 * About.astro
 * Bento-grid "About Me" section.
 *
 * CSS  → src/styles/about.css
 * JS   → src/scripts/about-map.ts
 *        src/scripts/about-terminal.ts
 *        src/scripts/about-weather.ts
 *        src/scripts/about-gallery.ts
 */
import { getI18N } from '@/i18n';
import PhotocardCarousel from '@/components/PhotocardCarousel.astro';
import '../styles/about.css';

interface Props {
  currentLocale?: string;
}

const { currentLocale = 'en' } = Astro.props;
const i18n = getI18N({ currentLocale });
const t    = i18n.ABOUT;

const graduationYear = 2024;
const years = Math.max(1, new Date().getFullYear() - graduationYear);
const p1    = t.p1.replace('{years}', String(years));

// GitHub contributions heatmap
let ghContributions: { date: string; count: number; level: number }[] = [];
let ghTotal = 0;
try {
  const res = await fetch('https://github-contributions-api.jogruber.de/v4/AndresVGu?y=last');
  if (res.ok) {
    const data = await res.json();
    ghTotal        = data.total?.lastYear ?? 0;
    ghContributions = (data.contributions ?? []).slice(-140);
  }
} catch {}
---

<!-- ── Photocards carousel (outside bento) ──────────────────────────── -->
<PhotocardCarousel currentLocale={currentLocale} />

<div class="bento-about">

  <!-- ── 1. Bio ──────────────────────────────────────────────────────── -->
  <div class="bento-cell cell-bio">
    <p class="bio-tagline">{t.tagline}</p>
    <div class="bio-text [&_strong]:text-gray-900 dark:[&_strong]:text-white [&_strong]:font-semibold" set:html={p1}></div>
    <div class="bio-text mt-2 [&_strong]:text-gray-900 dark:[&_strong]:text-white [&_strong]:font-semibold" set:html={t.p2}></div>
    <p class="bio-focus mt-4">{t.focus}</p>
  </div>

  <!-- ── 3. Map ──────────────────────────────────────────────────────── -->
  <div class="bento-cell cell-map">
    <div id="leaflet-map"></div>
    <a
      href="https://www.google.com/maps/place/Toronto,+Ontario/@43.7183357,-79.4604575,12z"
      target="_blank"
      rel="noopener noreferrer"
      class="map-overlay map-overlay-link"
      aria-label="View Toronto on Google Maps"
    >
      <div class="map-dot-live"></div>
      <div class="map-overlay-text">
        <span>Toronto, ON</span>
        <span>{t.bento.basedHere}</span>
      </div>
    </a>
  </div>

  <!-- ── 4. Terminal ────────────────────────────────────────────────── -->
  <div class="bento-cell cell-terminal" id="terminal-container">
    <div class="terminal-window">
      <div class="terminal-dots">
        <span class="dot-red"></span>
        <span class="dot-yellow"></span>
        <span class="dot-green"></span>
        <span class="terminal-title">andrés@portfolio ~ </span>
      </div>
      <div class="terminal-body" id="terminal-body">
        <div id="terminal-history"></div>
        <div class="terminal-input-line">
          <span class="text-green-400">$&nbsp;</span>
          <span id="terminal-display" class="text-gray-300"></span>
          <span class="terminal-cursor">▌</span>
          <input
            id="terminal-input"
            type="text"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal input"
            class="terminal-hidden-input"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- ── 5. Interests / Hobbies ─────────────────────────────────────── -->
  <div class="bento-cell cell-interests">
    <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">{t.hobbiesTitle}</p>
    <div class="hobbies-grid">
      {t.hobbies.map((h: { icon: string; label: string }) => (
        <div class="hobby-pill">
          <span class="hobby-icon">{h.icon}</span>
          <span class="hobby-label">{h.label}</span>
        </div>
      ))}
      <div class="hobby-pill hobby-pill-langs">
        <span class="lang-pill pill-en">EN</span>
        <span class="lang-pill pill-fr">FR</span>
        <span class="lang-pill pill-es">ES</span>
      </div>
    </div>
  </div>

  <!-- ── 6. Weather ─────────────────────────────────────────────────── -->
  <div class="bento-cell cell-weather" id="weather-cell"
    data-feels-like={t.weather.feelsLike}
    data-loading={t.weather.loading}
    data-unavailable={t.weather.unavailable}
    data-clear-day={t.weather.clearDay}
    data-clear-night={t.weather.clearNight}
    data-partly-cloudy={t.weather.partlyCloudy}
    data-foggy={t.weather.foggy}
    data-drizzle={t.weather.drizzle}
    data-rain={t.weather.rain}
    data-snow={t.weather.snow}
    data-rain-showers={t.weather.rainShowers}
    data-snow-showers={t.weather.snowShowers}
    data-thunderstorm={t.weather.thunderstorm}
  >
    <img id="weather-bg-img" src="/weather/whether.png" alt="" aria-hidden="true" class="weather-bg-img" />
    <div class="weather-top">
      <div class="weather-top-left">
        <div class="weather-temp-row">
          <span class="weather-temp" id="weather-temp">--°</span>
          <span class="weather-desc" id="weather-desc">{t.weather.loading}</span>
        </div>
        <span class="weather-location">Toronto</span>
        <span class="weather-feels" id="weather-feels"></span>
      </div>
    </div>
    <div class="weather-hover-overlay">
      <span class="weather-time" id="weather-time">--:--:--</span>
      <span class="weather-date" id="weather-date"></span>
    </div>
  </div>

  <!-- ── 7. GitHub heatmap ──────────────────────────────────────────── -->
  <div class="bento-cell cell-github">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-gray-700 dark:text-gray-300">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">GitHub</span>
      </div>
      <span class="text-[10px] text-gray-400 dark:text-gray-500">{ghTotal} contributions</span>
    </div>

    {(() => {
      const COLS = Math.ceil(ghContributions.length / 7);
      const monthLabels: { label: string; col: number }[] = [];
      let lastMonth = -1;
      for (let col = 0; col < COLS; col++) {
        const dayIndex = col * 7;
        if (dayIndex >= ghContributions.length) break;
        const date  = new Date(ghContributions[dayIndex].date);
        const month = date.getMonth();
        if (month !== lastMonth) {
          monthLabels.push({ label: date.toLocaleDateString(currentLocale, { month: 'short' }), col });
          lastMonth = month;
        }
      }
      return (
        <div class="gh-month-row" style={`grid-template-columns: repeat(${COLS}, minmax(8px, 1fr))`}>
          {monthLabels.map(({ label, col }) => (
            <span class="gh-month-label" style={`grid-column: ${col + 1}`}>{label}</span>
          ))}
        </div>
      );
    })()}

    <div class="gh-heatmap">
      {ghContributions.map(day => {
        const formatted = new Date(day.date).toLocaleDateString(currentLocale, { month: 'short', day: 'numeric', year: 'numeric' });
        return <div class={`gh-cell gh-level-${day.level}`} title={`${formatted}: ${day.count}`}></div>;
      })}
    </div>
  </div>

  <!-- ── Gallery modal (rendered once, reused for all cards) ────────── -->
  <div id="gallery-modal-backdrop" class="hidden fixed inset-0 z-[9999] items-center justify-center bg-black/80 backdrop-blur-md">
    <button id="gallery-modal-close" aria-label="Close" class="fixed top-5 right-5 z-[10000] p-2 rounded-full text-white/70 hover:text-white bg-white/10 hover:bg-white/20 transition">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="gallery-modal-prev" aria-label="Previous" class="fixed left-4 top-1/2 -translate-y-1/2 z-[10000] p-2 rounded-full text-white/70 hover:text-white bg-white/10 hover:bg-white/20 transition">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="gallery-modal-next" aria-label="Next" class="fixed right-4 top-1/2 -translate-y-1/2 z-[10000] p-2 rounded-full text-white/70 hover:text-white bg-white/10 hover:bg-white/20 transition">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
    <div id="gallery-modal-card" class="relative select-none" style="width:min(280px,80vw); perspective:900px;">
      <div id="gallery-modal-inner" style="transform-style:preserve-3d; transition:transform 0s; will-change:transform;">
        <div class="gallery-face gallery-front" style="border-radius:24px; overflow:hidden; backface-visibility:hidden;">
          <img id="gallery-modal-img" src="" alt="" style="width:100%; aspect-ratio:2/3; object-fit:cover; object-position:top; display:block;" />
          <div id="gallery-modal-glare" class="absolute inset-0 pointer-events-none" style="border-radius:24px; mix-blend-mode:overlay; opacity:0; transition:opacity 300ms;"></div>
          <div id="gallery-modal-foil"  class="absolute inset-0 pointer-events-none" style="border-radius:24px; mix-blend-mode:color-dodge; opacity:0; transition:opacity 300ms;"></div>
          <div id="gallery-modal-shine" class="absolute inset-0 pointer-events-none" style="border-radius:24px; mix-blend-mode:screen; opacity:0; transition:opacity 300ms;"></div>
          <div class="absolute bottom-0 left-0 right-0 px-4 py-3" style="background:linear-gradient(to top,rgba(0,0,0,0.8),transparent); border-radius:0 0 24px 24px;">
            <p id="gallery-modal-label" class="text-white font-bold text-sm"></p>
          </div>
          <div class="absolute top-2 right-2 text-white/40 text-[10px]">click to flip</div>
        </div>
        <div class="gallery-face gallery-back" style="border-radius:24px; overflow:hidden; backface-visibility:hidden; transform:rotateY(180deg); position:absolute; inset:0;">
          <div style="width:100%; height:100%; aspect-ratio:2/3; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:1.5rem; background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);">
            <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#a78bfa,#60a5fa);display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:900;color:#fff;">AV</div>
            <p style="color:#fff;font-weight:700;font-size:1rem;">Andrés Villarreal</p>
            <p style="color:rgba(255,255,255,0.5);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;">Full-Stack Developer</p>
            <div class="absolute top-2 right-2 text-white/30 text-[10px]">click to flip back</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- ── Scripts ─────────────────────────────────────────────────────────────── -->
<script>
  import { initMap }      from '@/scripts/about-map';
  import { initTerminal } from '@/scripts/about-terminal';
  import { initWeather }  from '@/scripts/about-weather';
  import { initGalleryModal } from '@/scripts/about-gallery';
  import { initPhotocardCarousel } from '@/scripts/photocard-carousel';

  document.addEventListener('astro:page-load', () => {
    initMap();
    initTerminal();
    initWeather();
    initGalleryModal();
    initPhotocardCarousel();
  });
</script>
