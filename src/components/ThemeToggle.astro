---
import Sun from '../Icons/Sun.astro';
import Moon from '../Icons/Moon.astro';
import SystemIcon from '../Icons/SistemIcon.astro';

const THEMES = ["Light", "Dark", "System"]
---

<div class="theme-toggle-wrapper relative ml-1 mr-1">
  <button
    class="theme-toggle-btn appearance-none border-none flex hover:scale-125
           transition text-gray-700 dark:text-gray-200
           hover:text-yellow-500 dark:hover:text-yellow-400">
    <span class="sr-only">Choose theme</span>
    <Sun  data-theme-icon="light"  class="theme-toggle-icon size-5 transition-all"/>
    <Moon data-theme-icon="dark"   class="theme-toggle-icon absolute size-5 transition-all"/>
    <SystemIcon data-theme-icon="system" class="theme-toggle-icon absolute size-5 transition-all"/>
  </button>

  <div
    class="themes-menu absolute hidden top-8 right-0
           text-sm p-1 min-w-[8rem] rounded-xl
           border border-gray-200 dark:border-gray-600
           bg-white dark:bg-gray-900
           text-gray-700 dark:text-gray-200
           shadow-lg backdrop-blur-md z-50">
    <ul>
      {THEMES.map((theme) => (
        <li class="themes-menu-option px-3 py-2 cursor-default rounded-lg
                   hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
          {theme}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .themes-menu.open {
    display: block;
    animation: tt-scale-in 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
  @keyframes tt-scale-in {
    from { transform: scale(0.9) translateY(-4px); opacity: 0; }
    to   { transform: scale(1)   translateY(0);    opacity: 1; }
  }
</style>

<script>
  function initThemeToggles() {
    const matchMedia = window.matchMedia("(prefers-color-scheme: dark)");
    let removeOsListener: (() => void) | null = null;

    const getThemePreference = (): string =>
      (typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "system";

    const updateAllIcons = (pref: string) => {
      document.querySelectorAll<HTMLElement>(".theme-toggle-icon").forEach((el) => {
        el.style.scale = el.dataset.themeIcon === pref ? "1" : "0";
      });
    };

    const applyTheme = () => {
      if (removeOsListener) removeOsListener();
      const handler = () => applyTheme();
      matchMedia.addEventListener("change", handler);
      removeOsListener = () => matchMedia.removeEventListener("change", handler);

      const pref   = getThemePreference();
      const isDark = pref === "dark" || (pref === "system" && matchMedia.matches);
      updateAllIcons(pref);
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");
    };

    applyTheme();

    // Wire up every toggle wrapper independently
    document.querySelectorAll<HTMLElement>(".theme-toggle-wrapper").forEach((wrapper) => {
      const btn  = wrapper.querySelector<HTMLElement>(".theme-toggle-btn");
      const menu = wrapper.querySelector<HTMLElement>(".themes-menu");
      if (!btn || !menu) return;

      // Close this menu on outside click
      document.addEventListener("click", () => menu.classList.remove("open"));

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        // Close all other menus first
        document.querySelectorAll(".themes-menu.open").forEach((m) => {
          if (m !== menu) m.classList.remove("open");
        });
        menu.classList.toggle("open");
      });

      menu.querySelectorAll<HTMLElement>(".themes-menu-option").forEach((opt) => {
        opt.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          localStorage.setItem("theme", target.innerText.toLowerCase().trim());
          applyTheme();
          menu.classList.remove("open");
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initThemeToggles);
</script>
