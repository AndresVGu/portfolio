---
/**
 * SafariMockup.astro
 * Renders a Safari browser chrome frame around an image or GIF.
 */
interface Props {
  src: string;
  url?: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, url = '', width = 1203, height = 753, class: className = '' } = Astro.props;
---

<div class={`w-full rounded-xl overflow-hidden ring-1 ring-black/5 dark:ring-white/10 ${className}`}>
  <svg
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    width="100%"
    viewBox={`0 0 ${width} ${height}`}
    class="w-full h-auto"
  >
    <g clip-path="url(#safari-clip-outer)">
      <!-- Window background -->
      <path
        d="M0 52H1202V741C1202 747.627 1196.63 753 1190 753H12C5.37258 753 0 747.627 0 741V52Z"
        class="fill-[#E5E5E5] dark:fill-[#404040]"
      />
      <!-- Title bar background (outer) -->
      <path
        fill-rule="evenodd"
        clip-rule="evenodd"
        d="M0 12C0 5.37258 5.37258 0 12 0H1190C1196.63 0 1202 5.37258 1202 12V52H0L0 12Z"
        class="fill-[#E5E5E5] dark:fill-[#404040]"
      />
      <!-- Title bar background (inner) -->
      <path
        fill-rule="evenodd"
        clip-rule="evenodd"
        d="M1.06738 12C1.06738 5.92487 5.99225 1 12.0674 1H1189.93C1196.01 1 1200.93 5.92487 1200.93 12V51H1.06738V12Z"
        class="fill-white dark:fill-[#262626]"
      />
      <!-- Traffic lights -->
      <circle cx="27" cy="25" r="6" class="fill-[#E5E5E5] dark:fill-[#404040]" />
      <circle cx="47" cy="25" r="6" class="fill-[#E5E5E5] dark:fill-[#404040]" />
      <circle cx="67" cy="25" r="6" class="fill-[#E5E5E5] dark:fill-[#404040]" />
      <!-- URL bar -->
      <path
        d="M286 17C286 13.6863 288.686 11 292 11H946C949.314 11 952 13.6863 952 17V35C952 38.3137 949.314 41 946 41H292C288.686 41 286 38.3137 286 35V17Z"
        class="fill-[#E5E5E5] dark:fill-[#404040]"
      />
      <!-- Lock icon -->
      <path
        d="M566.269 32.085H572.426C573.277 32.085 573.696 31.666 573.696 30.74V25.985C573.696 25.147 573.353 24.722 572.642 24.652V23.084C572.642 20.672 571.036 19.51 569.348 19.51C567.659 19.51 566.053 20.672 566.053 23.084V24.671C565.393 24.773 565 25.192 565 25.985V30.74C565 31.666 565.418 32.085 566.269 32.085ZM567.272 22.97C567.272 21.491 568.211 20.678 569.348 20.678C570.478 20.678 571.423 21.491 571.423 22.97V24.639L567.272 24.646V22.97Z"
        fill="#A3A3A3"
      />
      <!-- URL text -->
      <text x="580" y="30" fill="#A3A3A3" font-size="12" font-family="Arial, sans-serif">
        {url}
      </text>
      <!-- Content image -->
      <image
        width="1200"
        height="700"
        x="1"
        y="52"
        preserveAspectRatio="xMidYMid slice"
        href={src}
        style="clip-path: url(#safari-clip-content)"
      />
    </g>
    <defs>
      <clipPath id="safari-clip-outer">
        <rect fill="white" width={width} height={height} />
      </clipPath>
      <clipPath id="safari-clip-content">
        <path
          d="M1 52H1201V741C1201 747.075 1196.08 752 1190 752H12C5.92486 752 1 747.075 1 741V52Z"
          fill="white"
        />
      </clipPath>
    </defs>
  </svg>
</div>
